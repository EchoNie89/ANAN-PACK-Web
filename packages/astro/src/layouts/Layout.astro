---
import "../styles/global.css";
import { getLocalImage } from "../lib/local-images";
import {
  buildOrganizationJsonLd,
  buildWebPageJsonLd,
  buildWebsiteJsonLd,
  getDefaultLocale,
  getSiteName,
  getSiteUrl,
  resolveSeoImage,
  toAbsoluteUrl,
} from "../lib/seo";
import { getSiteSettings } from "../lib/site-settings";

type JsonLdNode = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: { src: string; width?: number; height?: number; alt?: string } | string;
  noindex?: boolean;
  keywords?: string[];
  openGraphType?: "website" | "article";
  schemaType?: string;
  jsonLd?: JsonLdNode[];
  articlePublishedTime?: string;
  articleModifiedTime?: string;
}

const {
  title = "ANAN PACK",
  description = "Factory-direct packaging, trims, labels, and sourcing solutions for fashion brands.",
  canonicalPath,
  image,
  noindex = false,
  keywords = [],
  openGraphType = "website",
  schemaType = "WebPage",
  jsonLd = [],
  articlePublishedTime,
  articleModifiedTime,
} = Astro.props;

const siteSettings = await getSiteSettings();
const siteUrl = getSiteUrl();
const siteName = getSiteName();
const defaultSeoImage = getLocalImage("/images/home/hero-packaging.png");
const seoImage = resolveSeoImage(image ?? defaultSeoImage);
const canonicalUrl = toAbsoluteUrl(canonicalPath ?? Astro.url.pathname, siteUrl);
const absoluteSeoImage =
  seoImage && (toAbsoluteUrl(seoImage.src, siteUrl) ?? seoImage.src);
const robotsContent = noindex
  ? "noindex, follow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const pageSchema = buildWebPageJsonLd({
  title,
  description,
  type: schemaType,
  url: canonicalUrl,
  image: absoluteSeoImage,
});
const jsonLdNodes = [
  buildOrganizationJsonLd(siteSettings),
  buildWebsiteJsonLd(),
  pageSchema,
  ...jsonLd,
].filter(Boolean) as JsonLdNode[];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      document.documentElement.dataset.js = "true";
    </script>
    <link rel="preconnect" href="https://cdn.sanity.io" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#be6c0d" />
    {
      import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION && (
        <meta
          name="google-site-verification"
          content={import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION}
        />
      )
    }
    {
      import.meta.env.PUBLIC_BING_SITE_VERIFICATION && (
        <meta
          name="msvalidate.01"
          content={import.meta.env.PUBLIC_BING_SITE_VERIFICATION}
        />
      )
    }
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={openGraphType} />
    <meta property="og:locale" content={getDefaultLocale()} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {absoluteSeoImage && <meta property="og:image" content={absoluteSeoImage} />}
    {seoImage?.width && <meta property="og:image:width" content={String(seoImage.width)} />}
    {seoImage?.height && <meta property="og:image:height" content={String(seoImage.height)} />}
    {seoImage?.alt && <meta property="og:image:alt" content={seoImage.alt} />}
    <meta name="twitter:card" content={absoluteSeoImage ? "summary_large_image" : "summary"} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {absoluteSeoImage && <meta name="twitter:image" content={absoluteSeoImage} />}
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    {articleModifiedTime && <meta property="article:modified_time" content={articleModifiedTime} />}
    {siteUrl && <link rel="sitemap" href={toAbsoluteUrl("/sitemap.xml", siteUrl)} />}
    <title>{title}</title>
    {
      jsonLdNodes.map((node) => (
        <script type="application/ld+json" set:html={JSON.stringify(node)} />
      ))
    }
  </head>
  <body id="site-top">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <script is:inline>
      (() => {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          return;
        }

        const revealElements = Array.from(document.querySelectorAll("[data-reveal]"));

        if (revealElements.length === 0) {
          return;
        }

        if (!("IntersectionObserver" in window)) {
          revealElements.forEach((element) => element.classList.add("is-visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;

              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          },
          {
            threshold: 0.16,
            rootMargin: "0px 0px -10% 0px",
          },
        );

        revealElements.forEach((element) => observer.observe(element));
      })();
    </script>
  </body>
</html>
