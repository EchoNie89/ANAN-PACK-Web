---
import { aboutMenuItems } from "../../data/home";

interface Props {
  forceOpen?: boolean;
}

const { forceOpen = false } = Astro.props;
const normalizePath = (value: string) => {
  const path = value.split("#")[0] || "/";
  if (path === "/") return "/";
  return path.replace(/\/+$/, "");
};
const currentPath = normalizePath(Astro.url.pathname);
---

<div
  id="about-menu"
  data-menu-panel="about"
  data-open={forceOpen ? "true" : "false"}
  class="absolute left-1/2 top-full z-50 w-[226px] -translate-x-1/2 overflow-hidden bg-[#fffffa] shadow-[-4px_4px_20px_rgba(0,0,0,0.1)] transition duration-200 pointer-events-none invisible opacity-0 data-[open=true]:pointer-events-auto data-[open=true]:visible data-[open=true]:opacity-100 group-hover/nav:pointer-events-auto group-hover/nav:visible group-hover/nav:opacity-100 group-focus-within/nav:pointer-events-auto group-focus-within/nav:visible group-focus-within/nav:opacity-100"
>
  <nav aria-label="About Us menu">
    {
      aboutMenuItems.map((item) => {
        const isActive =
          currentPath === "/about-us" && item.href.endsWith("#our-story");

        return (
          <a
            href={item.href}
            data-menu-link
            data-about-section-link
            data-active={isActive ? "true" : "false"}
            class="flex h-[51px] items-center justify-center bg-white px-4 text-center text-base font-bold text-black transition hover:brightness-95 data-[active=true]:bg-nav-dropdown-active data-[active=true]:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-inset"
          >
            {item.title}
          </a>
        );
      })
    }
  </nav>
</div>
