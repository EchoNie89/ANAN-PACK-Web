---
import Container from '../../ui/Container.astro';
import SymbolIcon from '../../ui/SymbolIcon.astro';
import { contactNextSteps } from '../../../data/company';
import { getSiteContactDetails } from '../../../lib/site-settings';

const contactDetails = await getSiteContactDetails();

const emailHref = `mailto:${contactDetails.email}`;
const whatsappDigits = contactDetails.whatsapp.replace(/[^0-9]/g, '');
const whatsappHref = `whatsapp://send?phone=${whatsappDigits}`;
const whatsappFallbackHref = `https://wa.me/${whatsappDigits}`;
const phoneHref = `tel:${contactDetails.phone.replace(/[^+\d]/g, '')}`;
const mapsQuery = [contactDetails.address, contactDetails.location]
  .filter(Boolean)
  .join(', ');
const mapsHref = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(mapsQuery)}`;

const infoItems = [
  {
    label: 'Email',
    value: contactDetails.email,
    icon: 'contactMail',
    href: emailHref,
  },
  {
    label: 'WhatsApp',
    value: contactDetails.whatsapp,
    icon: 'whatsapp',
    href: whatsappHref,
    fallbackHref: whatsappFallbackHref,
  },
  {
    label: 'Phone',
    value: contactDetails.phone,
    icon: 'contactPhone',
    href: phoneHref,
  },
  {
    label: 'Address',
    value: contactDetails.address,
    icon: 'contactLocation',
    href: mapsHref,
    target: '_blank',
    rel: 'noopener noreferrer',
  },
  {
    label: 'Business Hours',
    value: contactDetails.businessHours,
    icon: 'contactClock',
  },
] as const;

const inputClass =
  'w-full rounded-soft border border-[#d9dee5] bg-white px-4 py-3 text-sm text-text-main outline-none transition placeholder:text-[#9ca3af] focus:border-brand focus:ring-2 focus:ring-brand/15';

---

<section id="project-form" class="bg-page-muted py-16 md:py-24">
  <Container class="!max-w-[1280px]">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_392px] lg:items-stretch">
      <div class="flex h-full flex-col rounded-soft bg-white p-6 shadow-card md:p-8">
        <div data-contact-form-shell class="flex h-full flex-col">
          <h2 class="text-3xl font-extrabold tracking-tight text-ink">
            Send Us Your Project Details
          </h2>
          <p class="mt-2 text-sm text-text-muted">
            One more detail you provide, the more accurate our quotation will be.
          </p>
          <form class="mt-8 flex flex-1 flex-col space-y-4" id="contact-project-form">
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label class="sr-only" for="contact-name">Name</label>
                <input
                  id="contact-name"
                  class={inputClass}
                  type="text"
                  name="name"
                  placeholder="* Name"
                  required
                  aria-invalid="false"
                  aria-describedby="contact-name-error"
                  data-fs-field
                />
                <p
                  id="contact-name-error"
                  class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                  data-fs-error="name"
                ></p>
              </div>
              <div>
                <label class="sr-only" for="contact-company">Company Name</label>
                <input
                  id="contact-company"
                  class={inputClass}
                  type="text"
                  name="company"
                  placeholder="* Company Name"
                  required
                  aria-invalid="false"
                  aria-describedby="contact-company-error"
                  data-fs-field
                />
                <p
                  id="contact-company-error"
                  class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                  data-fs-error="company"
                ></p>
              </div>
              <div class="md:col-span-2">
                <label class="sr-only" for="contact-email">Email</label>
                <input
                  id="contact-email"
                  class={inputClass}
                  type="email"
                  name="email"
                  placeholder="* Email"
                  required
                  aria-invalid="false"
                  aria-describedby="contact-email-error"
                  data-fs-field
                />
                <p
                  id="contact-email-error"
                  class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                  data-fs-error="email"
                ></p>
              </div>
              <div class="md:col-span-2">
                <label class="sr-only" for="contact-phone">WhatsApp / Phone</label
                >
                <input
                  id="contact-phone"
                  class={inputClass}
                  type="text"
                  name="phone"
                  placeholder="WhatsApp / Phone"
                  aria-invalid="false"
                  aria-describedby="contact-phone-error"
                  data-fs-field
                />
                <p
                  id="contact-phone-error"
                  class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                  data-fs-error="phone"
                ></p>
              </div>
              <div class="md:col-span-2">
                <label class="sr-only" for="contact-country"
                  >Country / Region</label
                >
                <input
                  id="contact-country"
                  class={inputClass}
                  type="text"
                  name="country"
                  placeholder="Country / Region"
                  aria-invalid="false"
                  aria-describedby="contact-country-error"
                  data-fs-field
                />
                <p
                  id="contact-country-error"
                  class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                  data-fs-error="country"
                ></p>
              </div>
            </div>

            <div class="hidden" aria-hidden="true">
              <label class="sr-only" for="contact-gotcha">Leave this field empty</label>
              <input
                id="contact-gotcha"
                type="text"
                name="_gotcha"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <div>
              <label class="sr-only" for="contact-message"
                >Project Details / Message</label
              >
              <textarea
                id="contact-message"
                class={`${inputClass} min-h-[160px] resize-y`}
                name="message"
                placeholder="* Project Details / Message"
                maxlength="1000"
                required
                aria-invalid="false"
                aria-describedby="contact-message-error contact-message-help"
                data-fs-field></textarea>
              <p
                id="contact-message-error"
                class="mt-2 text-xs leading-5 text-[#9d3748] empty:hidden"
                data-fs-error="message"
              ></p>
              <p id="contact-message-help" class="mt-2 text-right text-xs text-[#9ca3af]">
                <span data-contact-message-count>0</span> / 1000
              </p>
            </div>

            <div class="mt-auto space-y-4 pt-2">
              <div
                id="contact-form-error-summary"
                class="hidden rounded-soft border border-[#f0c7cb] bg-[#fff4f4] px-4 py-3 text-sm text-[#9d3748]"
                data-contact-form-error
                data-fs-error
                role="alert"
                tabindex="-1"
              ></div>

              <button
                type="submit"
                class="mt-auto flex w-full items-center justify-center rounded-soft bg-brand-dark px-6 py-3 text-sm font-bold text-white transition hover:bg-brand-deep focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 disabled:cursor-not-allowed disabled:bg-brand-dark/70 disabled:text-white/85 disabled:hover:bg-brand-dark/70"
                data-fs-submit-btn
              >
                <span data-submit-label>Submit Inquiry</span>
              </button>

              <p class="inline-flex items-center gap-2 text-xs text-text-muted">
                <SymbolIcon name="check" class="size-4" />
                We usually respond within 24 hours on business days.
              </p>
            </div>
          </form>
        </div>

        <div
          class="hidden h-full rounded-soft bg-brand-soft/45 p-3 md:p-4"
          data-contact-form-success
          aria-live="polite"
        >
          <div class="flex h-full flex-col rounded-soft bg-white p-6 shadow-card md:p-8">
            <div class="inline-flex w-fit items-center rounded-full bg-brand-soft/55 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-brand-contrast">
              Inquiry Received
            </div>
            <div class="mt-6 flex size-[52px] items-center justify-center rounded-full bg-[#f1e9dd] text-[#ac7431]">
              <SymbolIcon name="check" class="size-[28px]" />
            </div>
            <h2 class="mt-6 text-3xl font-extrabold tracking-tight text-ink">
              Thank You For Your Inquiry
            </h2>
            <p class="mt-4 max-w-xl text-sm leading-6 text-text-main">
              We've received your project details. Our team will review them and get back to you within 24 hours on business days.
            </p>
            <p class="mt-3 max-w-xl text-sm leading-6 text-text-muted">
              If your request is urgent, feel free to contact us via WhatsApp or email.
            </p>
            <div class="mt-8 grid gap-3 md:grid-cols-2">
              <div class="rounded-soft bg-surface-muted px-4 py-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-contrast">
                  Response Window
                </p>
                <p class="mt-2 text-sm leading-6 text-text-main">
                  Expect a reply within 24 hours on business days.
                </p>
              </div>
              <div class="rounded-soft bg-surface-muted px-4 py-4">
                <p class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand-contrast">
                  Urgent Support
                </p>
                <p class="mt-2 text-sm leading-6 text-text-main">
                  For faster follow-up, contact us directly via WhatsApp or email.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-5">
        <aside class="rounded-soft bg-white p-6 shadow-card md:p-7">
          <h2 class="text-2xl font-extrabold tracking-tight text-ink">
            Get In Touch With Us
          </h2>
          <div class="mt-6 space-y-5">
            {
              infoItems.map((item) => (
                <div class="flex items-start gap-3">
                  <div class="flex size-[52px] shrink-0 items-center justify-center rounded-full bg-[#f1e9dd] text-[#ac7431]">
                    <SymbolIcon name={item.icon} class="size-[30px]" />
                  </div>
                  <div>
                    <h3 class="text-sm font-bold text-ink">{item.label}</h3>
                    {
                      item.href ? (
                        <a
                          href={item.href}
                          target={item.target}
                          rel={item.rel}
                          data-whatsapp-fallback={item.fallbackHref}
                          class="mt-1 inline-block text-sm leading-6 text-text-muted transition hover:text-brand hover:underline"
                        >
                          {item.value}
                        </a>
                      ) : (
                        <p class="mt-1 text-sm leading-6 text-text-muted">
                          {item.value}
                        </p>
                      )
                    }
                  </div>
                </div>
              ))
            }
          </div>
        </aside>

        <aside class="rounded-soft bg-brand-soft/45 p-6 shadow-card md:p-7">
          <h2 class="text-xl font-extrabold tracking-tight text-ink">
            What Happens Next?
          </h2>
          <ol class="mt-6 space-y-4">
            {
              contactNextSteps.map((step, index) => (
                <li class="flex items-start gap-3 text-sm leading-6 text-text-main">
                  <span class="mt-0.5 flex size-5 shrink-0 items-center justify-center rounded-full bg-brand-deep text-xs font-semibold text-white">
                    {index + 1}
                  </span>
                  <span>{step}</span>
                </li>
              ))
            }
          </ol>
        </aside>
      </div>
    </div>
  </Container>
</section>

<script>
  import { initForm } from "@formspree/ajax";

  const formElement = document.querySelector("#contact-project-form");

  if (formElement instanceof HTMLFormElement && !formElement.dataset.formspreeBound) {
    formElement.dataset.formspreeBound = "true";

    const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID?.trim();
    const formShell = formElement.closest("[data-contact-form-shell]");
    const successShell = formShell?.parentElement?.querySelector("[data-contact-form-success]");
    const errorRegion = formElement.querySelector("[data-contact-form-error]");
    const submitButton = formElement.querySelector("[data-fs-submit-btn]");
    const submitLabel = formElement.querySelector("[data-submit-label]");
    const messageField = formElement.querySelector("#contact-message");
    const messageCount = formElement.querySelector("[data-contact-message-count]");
    const fieldElements = Array.from(formElement.querySelectorAll("[data-fs-field]")).filter(
      (element) =>
        element instanceof HTMLInputElement ||
        element instanceof HTMLTextAreaElement ||
        element instanceof HTMLSelectElement,
    );
    const fieldErrorMap = new Map(
      Array.from(formElement.querySelectorAll("[data-fs-error]"))
        .map((element) => {
          if (!(element instanceof HTMLElement)) return null;
          const fieldName = element.getAttribute("data-fs-error");
          return fieldName ? [fieldName, element] : null;
        })
        .filter(Boolean),
    );
    const fieldElementMap = new Map(
      fieldElements
        .map((element) => [element.getAttribute("name"), element])
        .filter(([fieldName]) => typeof fieldName === "string" && fieldName.length > 0),
    );

    const defaultSubmitLabel = submitLabel?.textContent?.trim() || "Submit Inquiry";
    const unavailableSubmitLabel = "Inquiry Form Unavailable";

    const updateMessageCount = () => {
      if (
        !(messageField instanceof HTMLTextAreaElement) ||
        !(messageCount instanceof HTMLElement)
      ) {
        return;
      }

      messageCount.textContent = String(messageField.value.length);
    };

    const clearError = () => {
      if (!(errorRegion instanceof HTMLElement)) return;
      errorRegion.textContent = "";
      errorRegion.classList.add("hidden");
      errorRegion.removeAttribute("data-fs-active");
    };

    const showError = (message) => {
      if (!(errorRegion instanceof HTMLElement)) return;
      errorRegion.textContent = message;
      errorRegion.classList.remove("hidden");
      errorRegion.setAttribute("data-fs-active", "");
      errorRegion.focus();
    };

    const clearFieldErrors = () => {
      fieldElements.forEach((element) => {
        element.setAttribute("aria-invalid", "false");
      });

      fieldErrorMap.forEach((element) => {
        element.textContent = "";
        element.removeAttribute("data-fs-active");
      });
    };

    const renderFieldErrors = (_, error) => {
      clearFieldErrors();

      if (!error) return;

      const allFieldErrors = error.getAllFieldErrors();

      allFieldErrors.forEach(([fieldName, fieldErrors]) => {
        const [firstError] = fieldErrors;
        if (!firstError?.message) return;

        const fieldKey = String(fieldName);
        const fieldElement = fieldElementMap.get(fieldKey);
        const fieldErrorElement = fieldErrorMap.get(fieldKey);

        if (fieldElement) {
          fieldElement.setAttribute("aria-invalid", "true");
        }

        if (fieldErrorElement) {
          fieldErrorElement.textContent = firstError.message;
          fieldErrorElement.setAttribute("data-fs-active", "");
        }
      });
    };

    const setButtonState = ({ disabled, label }) => {
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = disabled;
      }

      if (submitLabel instanceof HTMLElement) {
        submitLabel.textContent = label;
      }
    };

    const setSubmitting = (isSubmitting) => {
      setButtonState({
        disabled: isSubmitting,
        label: isSubmitting ? "Submitting..." : defaultSubmitLabel,
      });
    };

    const showSuccess = () => {
      clearError();

      if (formShell instanceof HTMLElement) {
        formShell.classList.add("hidden");
      }

      if (successShell instanceof HTMLElement) {
        successShell.classList.remove("hidden");
      }
    };

    const genericErrorMessage =
      "Unable to submit your inquiry right now. Please try again or contact us via WhatsApp or email.";

    updateMessageCount();

    if (messageField instanceof HTMLTextAreaElement) {
      messageField.addEventListener("input", updateMessageCount);
    }

    if (!formId) {
      showError("Form configuration is missing: PUBLIC_FORMSPREE_FORM_ID.");
      setButtonState({ disabled: true, label: unavailableSubmitLabel });
    } else {
      initForm({
        formElement,
        formId,
        useDefaultStyles: false,
        onSubmit: () => {
          clearError();
          clearFieldErrors();
        },
        onSuccess: (context) => {
          context.form.reset();
          window.location.href = "/thank-you";
        },
        onError: (context, error) => {
          const formErrors = error.getFormErrors().map((entry) => entry.message);
          const allFieldErrors = error.getAllFieldErrors();

          if (formErrors[0]) {
            showError(formErrors[0]);
          } else {
            clearError();
          }

          if (!formErrors[0] && allFieldErrors.length === 0) {
            showError(genericErrorMessage);
          }

          const firstInvalidField = allFieldErrors
            .map(([fieldName]) => fieldElementMap.get(String(fieldName)))
            .find(Boolean);

          if (firstInvalidField instanceof HTMLElement) {
            firstInvalidField.focus();
          }

          updateMessageCount();
        },
        onFailure: () => {
          showError(genericErrorMessage);
          updateMessageCount();
        },
        disable: () => {
          setSubmitting(true);
        },
        enable: () => {
          setSubmitting(false);
        },
        renderFieldErrors,
        renderSuccess: () => {},
        renderFormError: () => {},
      });
    }
  }

  document
    .querySelectorAll("[data-whatsapp-fallback]")
    .forEach((linkElement) => {
      if (
        !(linkElement instanceof HTMLAnchorElement) ||
        linkElement.dataset.whatsappBound
      ) {
        return;
      }

      linkElement.dataset.whatsappBound = "true";
      linkElement.addEventListener("click", () => {
        const fallbackHref = linkElement.dataset.whatsappFallback;

        if (!fallbackHref) return;

        const fallbackTimer = window.setTimeout(() => {
          if (document.visibilityState === "visible") {
            window.location.href = fallbackHref;
          }
        }, 900);

        const clearFallback = () => window.clearTimeout(fallbackTimer);

        window.addEventListener("pagehide", clearFallback, { once: true });
        document.addEventListener(
          "visibilitychange",
          () => {
            if (document.visibilityState === "hidden") {
              clearFallback();
            }
          },
          { once: true },
        );
      });
    });
</script>
