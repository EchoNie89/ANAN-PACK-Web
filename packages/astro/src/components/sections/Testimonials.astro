---
import { Image } from "astro:assets";
import Container from "../ui/Container.astro";
import TestimonialCard from "../ui/TestimonialCard.astro";
import { testimonials, metrics } from "../../data/home";
---

<section class="py-16 md:py-24">
  <Container>
    <div class="mx-auto max-w-[863px] text-center">
      <h2 class="text-[32px] font-extrabold tracking-[0.03em] text-text-main">
        Voices Of Our Partners
      </h2>
      <p class="mt-5 text-[16px] leading-6 text-text-muted md:text-[20px] md:leading-[22px]">
        Real feedback from brands we work with, Long-term partnerships built on trust and results.
      </p>
    </div>
    <div class="mt-[60px] grid items-stretch gap-8 md:grid-cols-2 lg:grid-cols-3 lg:gap-[38px]">
      {testimonials.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
    <div class="mt-[60px] rounded-[10px] border border-border bg-surface shadow-card">
      <div class="grid divide-y divide-border lg:grid-cols-4 lg:divide-x lg:divide-y-0">
        {metrics.map((m) => (
          <div class="flex items-center gap-5 px-6 py-7 lg:px-[38px] lg:py-[38px]">
            <div class="flex size-[49px] shrink-0 items-center justify-center">
              <Image src={m.icon} alt="" class="size-auto max-h-[49px] max-w-[49px]" />
            </div>
            <div class="text-left">
              <p class="text-[20px] font-bold leading-5 text-text-main">{m.value}</p>
              <p class="mt-1 text-[14px] font-medium leading-5 text-text-main">{m.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </Container>
</section>
