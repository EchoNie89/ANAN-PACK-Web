---
import Container from "../ui/Container.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import TestimonialCard from "../ui/TestimonialCard.astro";
import { testimonials } from "../../data/home";
---

<section class="bg-white py-16 md:py-24">
  <Container>
    <SectionTitle
      title="Voices Of Our Partners"
      description="Real feedback from brands who needed small-batch, custom packaging without supplier chaos."
    />
    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((testimonial) => <TestimonialCard {...testimonial} />)}
    </div>
  </Container>
</section>
