---
import Container from "../../ui/Container.astro";
import SolutionLineIcon from "../../ui/SolutionLineIcon.astro";
import type { SolutionPageData } from "../../../data/solutions";

interface Props {
  page: SolutionPageData;
}

const { page } = Astro.props;
---

<section class="bg-white py-12 md:py-16">
  <Container class="!max-w-[1200px]">
    <h2 class="text-center font-display text-xl font-black tracking-[0.02em] text-ink md:text-[26px]">
      {page.challenges.title}
    </h2>
    <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-4 lg:gap-10">
      {
        page.challenges.items.map((item) => (
          <article class="text-center">
            <div class="mx-auto flex size-16 items-center justify-center rounded-full bg-white shadow-card">
              <SolutionLineIcon icon={item.icon} />
            </div>
            <h3 class="mt-5 text-sm font-extrabold text-ink md:text-base">{item.title}</h3>
            <p class="mx-auto mt-3 max-w-64 text-xs leading-6 text-text-muted md:text-sm">
              {item.description}
            </p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
