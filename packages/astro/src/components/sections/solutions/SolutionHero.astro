---
import Button from "../../ui/Button.astro";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import type { SolutionPageData } from "../../../data/solutions";

interface Props {
  page: SolutionPageData;
}

const { page } = Astro.props;
---

<section class="relative overflow-hidden bg-brand-soft md:h-[474px]">
  <div class="absolute inset-0">
    <LocalImage
      src={page.hero.image}
      alt={page.hero.alt}
      class="size-full object-cover object-top"
      loading="eager"
      sizes="100vw"
      widths={[640, 960, 1280, 1600, 1920]}
      priority
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/28 via-black/10 to-transparent"></div>
  </div>

  <Container class="relative flex h-full flex-col !max-w-[1200px] py-9 text-white md:py-12">
    <nav class="motion-enter text-[14px]" aria-label="Breadcrumb" style="--motion-delay: 80ms;">
      <ol class="flex flex-wrap items-center gap-3 md:gap-4">
        <li><a href="/" class="font-normal text-white/75 transition hover:text-white">Home</a></li>
        <li aria-hidden="true" class="text-white/75">&gt;</li>
        <li><a href="/solutions/" class="font-normal text-white/75 transition hover:text-white">Solutions</a></li>
        <li aria-hidden="true" class="text-white/75">&gt;</li>
        <li class="font-normal text-white">{page.breadcrumb}</li>
      </ol>
    </nav>

    <div class="mt-10 max-w-4xl md:mt-16 lg:max-w-[1030px]">
      <h1
        class="motion-enter font-display text-3xl font-black leading-tight tracking-[0.01em] text-white md:text-5xl lg:text-[52px] lg:leading-[1.15]"
        style="--motion-delay: 160ms;"
      >
        {page.hero.title}
      </h1>
      <p
        class="motion-enter mt-5 max-w-[1160px] text-base font-medium leading-7 text-white/90 md:text-xl md:leading-8"
        style="--motion-delay: 240ms;"
      >
        {page.hero.description}
      </p>
      <div class="motion-enter mt-6 md:mt-10" style="--motion-delay: 320ms;">
        <Button
          href="/contact-us#project-form"
          variant="secondary"
          class="!h-10 w-[195px] !rounded-[8px] border-0 !bg-[#E6DBCB] !px-0 !py-0 !text-[16px] !font-semibold !normal-case !tracking-normal !text-[#333333] transition hover:!bg-[#d4c9b5]"
        >
          {page.hero.cta}
        </Button>
      </div>
    </div>
  </Container>
</section>
