---
import { Image } from "astro:assets";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import type { SolutionPageData } from "../../../data/solutions";
import solutionCaseStudyQuoteImage from "../../../assets/solutions/solution-case-study-quote.png";

interface Props {
  page: SolutionPageData;
}

const { page } = Astro.props;
---

<section class="bg-white py-14 md:py-20">
  <Container class="!max-w-[1280px]">
    <div class="grid gap-8 md:gap-10 lg:grid-cols-[minmax(0,531px)_minmax(0,609px)] lg:justify-between lg:gap-[60px]">
      <div class="overflow-hidden bg-surface-muted">
        <LocalImage
          src={page.caseStudy.image}
          alt={page.caseStudy.alt}
          class="aspect-[531/545] size-full object-cover"
          loading="lazy"
          sizes="(min-width: 1024px) 50vw, 100vw"
          widths={[480, 720, 960, 1280]}
        />
      </div>

      <div>
        <h2 class="text-[30px] font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
          {page.caseStudy.title}
        </h2>
        <h3 class="mt-4 max-w-[609px] text-[22px] font-bold leading-[1.5] text-text-main md:text-[24px]">
          {page.caseStudy.headline}
        </h3>
        <p class="mt-5 max-w-[605px] text-[15px] leading-[1.5] text-text-muted text-justify">
          {page.caseStudy.intro}
        </p>

        <div class="mt-10 max-w-[608px]">
          <Image
            src={solutionCaseStudyQuoteImage}
            alt=""
            width={28}
            height={22}
            class="h-auto w-[28px]"
          />
          <blockquote class="mt-3 text-[14px] italic leading-[22px] text-text-muted text-justify">
            {page.caseStudy.quote}
          </blockquote>
          <p class="mt-6 text-[15px] font-bold italic leading-[22px] text-text-main">
            {page.caseStudy.attribution}
          </p>
        </div>

        <a
          href="/blog"
          class="mt-10 inline-flex h-[50px] w-[180px] items-center justify-center rounded-[200px] bg-[#E6DBCB] text-[18px] font-semibold leading-none text-text-main transition hover:bg-[#d9c7af] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
        >
          View More
        </a>
      </div>
    </div>

    <div class="mt-10 grid gap-8 md:mt-12">
      {
        page.caseStudy.sections.map((section) => (
          <article>
            <h3 class="text-base font-bold text-text-main md:text-lg">{section.title}</h3>
            {section.body && <p class="mt-3 text-sm leading-7 text-text-muted md:text-[15px]">{section.body}</p>}
            {section.bullets && (
              <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-7 text-text-muted md:text-[15px]">
                {section.bullets.map((bullet) => <li>{bullet}</li>)}
              </ul>
            )}
          </article>
        ))
      }
    </div>
  </Container>
</section>
