---
import Container from "../../ui/Container.astro";
import type { SolutionPageData } from "../../../data/solutions";

interface Props {
  page: SolutionPageData;
}

const { page } = Astro.props;
---

<section class="bg-white py-14 md:py-20">
  <Container class="!max-w-[1200px]">
    <h2 class="text-center font-display text-xl font-black tracking-[0.02em] text-ink md:text-[28px]">
      {page.eco.title}
    </h2>
    <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-12">
      {
        page.eco.columns.map((column) => (
          <article class="text-center md:text-left">
            <h3 class="mx-auto max-w-[310px] font-display text-2xl font-light leading-tight text-black md:min-h-[76px] md:text-center md:text-[30px]">
              {column.title}
            </h3>
            <p class="mt-8 text-sm font-bold leading-7 text-text-muted">{column.kicker}</p>
            <p class="mt-2 text-sm leading-7 text-text-muted">{column.description}</p>
          </article>
        ))
      }
    </div>

    <div class="mt-14 border-y border-black/20 py-8 md:mt-20">
      <div class="flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
        <h3 class="font-display text-xl font-black tracking-[0.02em] text-black md:text-[28px]">
          {page.eco.cta}
        </h3>
        <a
          href="/blog"
          class="inline-flex h-11 min-w-32 items-center justify-center rounded-button bg-brand-soft px-8 text-sm font-semibold uppercase text-text-main transition hover:bg-border focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2"
        >
          GO
        </a>
      </div>
    </div>
  </Container>
</section>
