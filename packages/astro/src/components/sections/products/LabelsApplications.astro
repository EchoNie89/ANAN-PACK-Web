---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard } from "../../../data/products";

interface Props {
  title?: string;
  description?: string;
  applications: ProductCard[];
  layout?: "grid" | "balanced";
}

const {
  title = "Applications",
  description,
  applications,
  layout = "grid",
} = Astro.props;

const itemClass = (index: number) =>
  layout === "balanced"
    ? index === 3
      ? "md:col-span-2 md:col-start-2"
      : index === 4
        ? "md:col-span-2 md:col-start-4"
        : "md:col-span-2"
    : "";
---

<section class="bg-white py-16">
  <Container class="!max-w-[1200px] px-5 sm:px-6 lg:px-5">
    <div class="text-center">
      <h2 class="text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
        {title}
      </h2>
      {
        description && (
          <p class="mx-auto mt-5 text-base font-semibold leading-7 text-text-main md:text-2xl md:leading-9">
            {description}
          </p>
        )
      }
    </div>
    <div class={`mt-10 grid grid-cols-2 gap-x-4 gap-y-8 md:gap-x-7 ${layout === "balanced" ? "sm:grid-cols-4 md:grid-cols-6 lg:mt-14" : "sm:grid-cols-3 lg:mt-14 lg:grid-cols-4 lg:gap-x-7"}`}>
      {
        applications.map((item, index) => (
          <article class={`w-full text-center ${itemClass(index)}`}>
            <h3 class="mb-3 text-base font-semibold leading-snug text-text-main md:mb-4 md:text-xl md:leading-tight">
              {item.title}
            </h3>
            <div class="group aspect-[4/3] overflow-hidden border border-border bg-surface-muted">
              <SanityImage
                image={item.image}
                class="size-full object-cover transition duration-500 group-hover:scale-105"
                sizes="(min-width: 1024px) 220px, (min-width: 640px) 30vw, 45vw"
              />
            </div>
            {
              item.description && (
                <p class="mt-3 text-sm leading-6 text-text-muted md:mt-4 md:text-base">
                  {item.description}
                </p>
              )
            }
          </article>
        ))
      }
    </div>
  </Container>
</section>
