---
import Container from "../../ui/Container.astro";
import type { ProductFaq } from "../../../data/products";

interface Props {
  faqs: ProductFaq[];
  title?: string;
}

const { faqs, title = "FAQs" } = Astro.props;
---

<section class="bg-white pb-14 md:pb-16">
  <Container class="!max-w-[1280px]">
    <h2 class="text-center text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      {title}
    </h2>
    <div class="mt-8 divide-y divide-border border-y border-border bg-white">
      {
        faqs.map((faq, index) => (
          <details class="group py-4 open:bg-[#fefaf3]" open={index === 0}>
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 rounded-sm text-[15px] font-semibold leading-6 text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 md:items-center md:gap-6 md:text-base">
              <span>{faq.question}</span>
              <svg
                viewBox="0 0 12 8"
                class="mt-1 size-4 shrink-0 text-[#9a9a9a] transition-transform duration-200 group-open:rotate-180 group-open:text-text-main"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M6 8 0 0h12L6 8Z" />
              </svg>
            </summary>
            <p class="mt-3 max-w-4xl text-sm leading-6 text-text-muted md:leading-7">
              {faq.answer}
            </p>
          </details>
        ))
      }
    </div>
  </Container>
</section>
