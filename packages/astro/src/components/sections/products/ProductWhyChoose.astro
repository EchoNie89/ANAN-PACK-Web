---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard } from "../../../data/products";

interface Props {
  title: string;
  items: ProductCard[];
}

const { title, items } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <Container class="!max-w-[1280px]">
    <h2 class="text-center text-xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      {title}
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        items.map((item) => (
          <article>
            <div class="aspect-[4/3] overflow-hidden bg-surface-muted">
              <SanityImage
                image={item.image}
                class="size-full object-cover"
                sizes="(min-width: 768px) 33vw, 100vw"
              />
            </div>
            <div class="mt-5">
              <h3 class="text-base font-extrabold leading-tight text-ink">{item.title}</h3>
              {
                item.description && (
                  <p class="mt-3 text-sm leading-6 text-text-muted">{item.description}</p>
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
