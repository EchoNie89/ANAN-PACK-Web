---
import PageCTA from '../PageCTA.astro';
import type { ProductPageData } from '../../../data/products';
import LabelsApplications from './LabelsApplications.astro';
import LabelsCaseStudy from './LabelsCaseStudy.astro';
import LabelsCustomization from './LabelsCustomization.astro';
import LabelsFaq from './LabelsFaq.astro';
import LabelsFeatureBand from './LabelsFeatureBand.astro';
import LabelsIntro from './LabelsIntro.astro';
import LabelsProcess from './LabelsProcess.astro';
import LabelsShowcase from './LabelsShowcase.astro';
import LabelsStyles from './LabelsStyles.astro';
import LabelsWhyChoose from './LabelsWhyChoose.astro';
import ProductHero from './ProductHero.astro';

interface Props {
  page: ProductPageData;
}

const { page } = Astro.props;
---

<main>
  <ProductHero
    title={page.title}
    subtitle={page.subtitle}
    navLabel={page.navLabel}
    heroTone={page.heroTone}
    heroAlign={page.heroAlign}
    heroOverlay={page.heroOverlay}
    heroButtonPlacement={page.heroButtonPlacement}
    heroTitleLines={page.heroTitleLines}
    heroImage={page.heroImage}
  />
  <LabelsFeatureBand />
  <LabelsIntro />
  <LabelsShowcase />
  <LabelsApplications />
  <LabelsCustomization />
  <LabelsProcess />
  <LabelsWhyChoose />
  <LabelsCaseStudy />
  <LabelsFaq />
  <PageCTA
    title="Want To Upgrade Your Brand's Packaging?"
    description="Send us your design, get a quote within 6 hours."
    href="/contact-us"
    buttonLabel="Request A Quote"
    note="We'll reply within 6 hours."
    tone="tan"
    class="bg-surface"
  />
</main>
