---
import Container from '../../ui/Container.astro';
import ProductImageTile from '../../ui/ProductImageTile.astro';
import type { ProductShowcaseGroup } from '../../../data/products';

interface Props {
  slug: string;
  showcaseGroups?: ProductShowcaseGroup[];
}

const { slug, showcaseGroups = [] } = Astro.props;
---

<section class="bg-white pb-14 md:pb-20">
  <Container class="!max-w-[1200px]">
    <h2
      class="text-center text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]"
    >
      Product Showcase
    </h2>
    <div class="mt-7 grid gap-10 md:gap-12">
      {
        showcaseGroups.map((group) => (
          <section>
            <h3 class="text-lg font-extrabold text-ink md:text-xl">
              {group.title}
            </h3>
            {group.description && (
              <p class="mt-1 text-[18px] text-ink/60">
                {group.description}
              </p>
            )}
            <div class="mt-5 grid grid-cols-2 gap-x-4 gap-y-7 sm:grid-cols-3 md:gap-x-7 lg:grid-cols-4">
              {group.cards.map((item) => (
                <ProductImageTile
                  title={item.title}
                  image={item.image.src}
                  alt={item.image.alt || item.title}
                />
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </Container>
</section>
