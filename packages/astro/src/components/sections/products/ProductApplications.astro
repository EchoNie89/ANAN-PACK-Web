---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard } from "../../../data/products";

interface Props {
  title?: string;
  description?: string;
  applications: ProductCard[];
  layout?: "grid" | "balanced";
}

const {
  title = "Applications",
  description,
  applications,
  layout = "grid",
} = Astro.props;

const isThreeCardLayout = applications.length === 3;

const itemClass = (index: number) =>
  isThreeCardLayout
    ? ""
    : layout === "balanced"
    ? index === 3
      ? "md:col-span-2 md:col-start-2"
      : index === 4
        ? "md:col-span-2 md:col-start-4"
        : "md:col-span-2"
    : "";
---

<section class="bg-white py-16">
  <Container class="!max-w-[1280px] px-5 sm:px-6 lg:px-5">
    <div class="text-center" data-reveal>
      <h2 class="text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
        {title}
      </h2>
      {
        description && (
          <p class="mx-auto mt-5 text-base font-semibold leading-7 text-text-main md:text-2xl md:leading-9">
            {description}
          </p>
        )
      }
    </div>
    <div class={`mt-10 grid gap-x-4 gap-y-8 md:gap-x-7 ${isThreeCardLayout ? "grid-cols-1 sm:grid-cols-2 lg:mt-14 lg:grid-cols-3 lg:gap-x-8 lg:gap-y-0" : layout === "balanced" ? "grid-cols-2 sm:grid-cols-4 md:grid-cols-6 lg:mt-14" : "grid-cols-2 sm:grid-cols-3 lg:mt-14 lg:grid-cols-4 lg:gap-x-7"}`}>
      {
        applications.map((item, index) => (
          <article
            class={`motion-hover-card w-full text-center ${isThreeCardLayout ? "mx-auto max-w-[378px]" : ""} ${itemClass(index)}`}
            data-reveal
            style={`--reveal-delay: ${index * 70}ms;`}
          >
            <h3 class={isThreeCardLayout
              ? "mb-4 text-[18px] font-semibold leading-[1.5] text-text-main md:mb-5 md:text-[20px]"
              : "mb-3 text-base font-semibold leading-snug text-text-main md:mb-4 md:text-xl md:leading-tight"}>
              {item.title}
            </h3>
            <div class={`group overflow-hidden border border-border bg-surface-muted ${isThreeCardLayout ? "aspect-[378/265]" : "aspect-[4/3]"}`}>
              <SanityImage
                image={item.image}
                class="size-full object-cover transition duration-500 group-hover:scale-105"
                sizes={isThreeCardLayout ? "(min-width: 1024px) 378px, (min-width: 640px) 45vw, 100vw" : "(min-width: 1024px) 220px, (min-width: 640px) 30vw, 45vw"}
              />
            </div>
            {
              item.description && (
                <p class={isThreeCardLayout
                  ? "mx-auto mt-4 max-w-[378px] text-[15px] leading-[26px] text-text-main md:mt-5"
                  : "mt-3 text-sm leading-6 text-text-muted md:mt-4 md:text-base"}>
                  {item.description}
                </p>
              )
            }
          </article>
        ))
      }
    </div>
  </Container>
</section>
