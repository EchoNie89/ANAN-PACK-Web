---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard } from "../../../data/products";

interface Props {
  title?: string;
  description?: string;
  applications: ProductCard[];
  layout?: "grid" | "balanced";
}

const {
  title = "Applications",
  description,
  applications,
  layout = "grid",
} = Astro.props;

const itemClass = (index: number) =>
  layout === "balanced"
    ? index === 3
      ? "md:col-span-2 md:col-start-2"
      : index === 4
        ? "md:col-span-2 md:col-start-4"
        : "md:col-span-2"
    : "";
---

<section class="bg-white pb-14 md:pb-20">
  <Container class="!max-w-[1200px]">
    <div class="text-center">
      <h2 class="text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
        {title}
      </h2>
      {
        description && (
          <p class="mx-auto mt-4 max-w-[1200px] text-base font-semibold leading-7 text-text-main md:mt-5 md:text-2xl md:leading-[37px]">
            {description}
          </p>
        )
      }
    </div>
    <div class={`mt-10 grid gap-x-4 gap-y-8 sm:grid-cols-2 md:gap-x-10 md:gap-y-10 ${layout === "balanced" ? "md:grid-cols-6" : "lg:grid-cols-3"}`}>
      {
        applications.map((item, index) => (
          <article class={`mx-auto w-full max-w-[373px] text-center ${itemClass(index)}`}>
            <h3 class="mb-4 text-lg font-semibold leading-[1.5] text-text-main md:mb-5 md:text-xl">
              {item.title}
            </h3>
            <div class="aspect-[1.52] overflow-hidden bg-surface-muted">
              <SanityImage
                image={item.image}
                class="size-full object-cover"
                sizes="(min-width: 768px) 373px, 100vw"
              />
            </div>
            {
              item.description && (
                <p class="mx-auto mt-4 max-w-[353px] text-sm leading-6 text-text-main md:text-[15px]">
                  {item.description}
                </p>
              )
            }
          </article>
        ))
      }
    </div>
  </Container>
</section>
