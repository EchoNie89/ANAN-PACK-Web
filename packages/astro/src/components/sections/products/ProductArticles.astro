---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard } from "../../../data/products";

interface Props {
  blogs: ProductCard[];
}

const { blogs } = Astro.props;
---

<section class="bg-white py-16 md:py-20">
  <Container class="!max-w-[1200px]">
    <h2 class="text-center text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      Why Choose Us for Your Branded Packaging?
    </h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        blogs.map((post) => (
          <article class="grid gap-4">
            <SanityImage
              image={post.image}
              class="aspect-[1.45] size-full object-cover"
              sizes="(min-width: 768px) 33vw, 100vw"
            />
            <div>
              <h3 class="text-base font-extrabold text-ink">{post.title}</h3>
              <p class="mt-3 text-sm leading-6 text-text-muted">{post.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
