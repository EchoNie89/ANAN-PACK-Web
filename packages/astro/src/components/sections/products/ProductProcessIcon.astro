---
import LocalImage from "../../ui/LocalImage.astro";
import { getLocalImage } from "../../../lib/local-images";
import type { ProductProcessIcon } from "../../../data/products";

interface Props {
  name: ProductProcessIcon | "guaranteeing";
  class?: string;
}

const { name, class: className = "" } = Astro.props;

const normalizedName = name === "guaranteing" ? "guaranteeing" : name;

const iconImages = {
  concept: getLocalImage("/images/products/process/concept.svg"),
  designing: getLocalImage("/images/products/process/designing.svg"),
  manufacturing: getLocalImage("/images/products/process/manufacturing.svg"),
  testing: getLocalImage("/images/products/process/testing.svg"),
  packaging: getLocalImage("/images/products/process/packaging.svg"),
  guaranteeing: getLocalImage("/images/products/process/guaranteeing.svg"),
} as const;

const iconImage = iconImages[normalizedName];
---

<div
  class={`flex size-28 items-center justify-center rounded-full bg-white text-black shadow-[0_4px_5px_rgba(0,0,0,0.05)] md:size-[122px] ${className}`}
>
  <LocalImage
    src={iconImage}
    alt=""
    aria-hidden="true"
    class="size-14 object-contain md:size-[74px]"
    loading="eager"
    width={74}
    height={74}
  />
</div>
