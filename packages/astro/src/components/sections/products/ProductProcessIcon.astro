---
import type { ProductProcessIcon } from "../../../data/products";

interface Props {
  name: ProductProcessIcon | "guaranteeing";
  class?: string;
}

const { name, class: className = "" } = Astro.props;
const iconClass = "size-14 text-black md:size-[74px]";
---

<div
  class={`flex size-28 items-center justify-center rounded-full bg-white text-black shadow-[0_4px_5px_rgba(0,0,0,0.05)] md:size-[122px] ${className}`}
>
  {
    name === "concept" && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M32 7c-11 0-20 8.4-20 19 0 7 3.6 12 8.5 15.5 2.3 1.7 3.5 4.2 3.5 7V50h16v-1.5c0-2.8 1.3-5.4 3.6-7C48.4 38 52 33 52 26 52 15.4 43 7 32 7Z" />
        <path d="M25 57h14M27 50h10" />
      </svg>
    )
  }
  {
    name === "designing" && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m12 45 7 7 33-33-7-7-33 33Z" />
        <path d="m39 18 7 7M12 45l-2 9 9-2M22 14l-8 8 28 28 8-8M17 19l5 5M42 44l5 5" />
      </svg>
    )
  }
  {
    name === "manufacturing" && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M23 6v15l-5 5-5-5V6M18 26v30" />
        <path d="M11 56h14M41 6l7 7-5 13 8 24-7 7-8-24-13-5 7-18 11-4Z" />
        <path d="m30 10 13 16" />
      </svg>
    )
  }
  {
    name === "testing" && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 12h20l2 8h8v36H12V20h8l2-8Z" />
        <path d="M22 20h20M23 33l5 5 10-11M23 47l5 5M28 47l-5 5M42 36h8M42 50h8" />
      </svg>
    )
  }
  {
    name === "packaging" && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m8 20 24-12 24 12-24 12L8 20Z" />
        <path d="M8 20v26l24 12 24-12V20M32 32v26M20 14l24 12" />
      </svg>
    )
  }
  {
    (name === "guaranteing" || name === "guaranteeing") && (
      <svg viewBox="0 0 64 64" class={iconClass} fill="none" stroke="currentColor" stroke-width="4.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m32 6 20 8v15c0 13-8 23-20 29-12-6-20-16-20-29V14l20-8Z" />
        <path d="m23 32 7 7 13-14" />
      </svg>
    )
  }
</div>
