---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductPageData } from "../../../data/products";

interface Props {
  caseStudy: ProductPageData["caseStudy"];
}

const { caseStudy } = Astro.props;
const resultPoints = caseStudy.resultPoints?.length ? caseStudy.resultPoints : caseStudy.bullets;
const challengeParagraphs = caseStudy.challenge
  ?.split(/\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
---

<section class="bg-white py-14 md:py-20">
  <Container class="!max-w-[1280px]">
    <div class="grid gap-8 md:gap-10 lg:grid-cols-[minmax(0,531px)_minmax(0,609px)] lg:justify-between lg:gap-[60px]">
      <div class="overflow-hidden bg-surface-muted" data-reveal>
        <SanityImage
          image={caseStudy.image}
          class="aspect-[531/545] size-full object-cover"
          sizes="(min-width: 1024px) 50vw, 100vw"
        />
      </div>

      <div data-reveal style="--reveal-delay: 100ms;">
        <h2 class="text-[30px] font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
          Case Study
        </h2>
        <h3 class="mt-4 max-w-[609px] text-[22px] font-bold leading-[1.5] text-text-main md:text-[24px]">
          {caseStudy.title}
        </h3>
        <p class="mt-5 max-w-[605px] text-[15px] leading-[1.5] text-text-muted text-justify">
          {caseStudy.description}
        </p>

        {
          caseStudy.quote && (
            <div class="mt-10 max-w-[608px]">
              <div class="text-[68px] font-extrabold leading-none text-text-main md:text-[80px]">“</div>
              <blockquote class="-mt-3 text-[14px] italic leading-[22px] text-text-muted text-justify">
                {caseStudy.quote}
              </blockquote>
              {caseStudy.quoteAuthor && (
                <p class="mt-6 text-[15px] font-bold italic leading-[22px] text-text-main">
                  {caseStudy.quoteAuthor}
                </p>
              )}
            </div>
          )
        }

        <a
          href="/contact-us"
          class="mt-10 inline-flex h-[50px] w-[180px] items-center justify-center rounded-[200px] bg-[#E6DBCB] text-[18px] font-semibold leading-none text-text-main transition hover:bg-[#d9c7af] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
        >
          View More
        </a>
      </div>
    </div>

    <div class="mt-10 grid gap-6 text-sm leading-6 text-text-muted" data-reveal style="--reveal-delay: 140ms;">
      {
        caseStudy.challenge && (
          <section>
            <h3 class="text-base font-extrabold text-ink">The Challenge:</h3>
            <div class="mt-3 grid gap-3">
              {challengeParagraphs?.map((paragraph) => <p class="text-justify">{paragraph}</p>)}
            </div>
          </section>
        )
      }

      {
        (caseStudy.solutionIntro || caseStudy.solutionPoints?.length) && (
          <section>
            <h3 class="text-base font-extrabold text-ink">Our Solution:</h3>
            {caseStudy.solutionIntro && <p class="mt-3 text-justify">{caseStudy.solutionIntro}</p>}
            {caseStudy.solutionPoints?.length ? (
              <ul class="mt-2 grid gap-1">
                {caseStudy.solutionPoints.map((point) => (
                  <li class="flex gap-2">
                    <span class="mt-2 size-1 shrink-0 rounded-full bg-text-muted"></span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            ) : null}
          </section>
        )
      }

      <section>
        <h3 class="text-base font-extrabold text-ink">The Results:</h3>
        <ul class="mt-3 grid gap-1">
          {
            resultPoints.map((point) => (
              <li class="flex gap-2">
                <span class="mt-2 size-1 shrink-0 rounded-full bg-text-muted"></span>
                <span>{point}</span>
              </li>
            ))
          }
        </ul>
      </section>
    </div>

    {
      caseStudy.gallery?.length ? (
        <div class="mt-12 grid gap-6 md:mt-20 md:grid-cols-2">
          {caseStudy.gallery.map((image, index) => (
            <div data-reveal style={`--reveal-delay: ${index * 80}ms;`}>
              <SanityImage
                image={image}
                class="aspect-[1.05] size-full object-cover"
                sizes="(min-width: 768px) 50vw, 100vw"
              />
            </div>
          ))}
        </div>
      ) : null
    }
  </Container>
</section>
