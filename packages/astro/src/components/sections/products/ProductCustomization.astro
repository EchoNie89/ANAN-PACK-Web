---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCustomizationGroup } from "../../../data/products";
import type { CustomizationMarkerStyle } from "../../../lib/customization-content";

interface Props {
  groups?: ProductCustomizationGroup[];
}

const { groups = [] } = Astro.props;

const markerClassByStyle = {
  bullet: "list-disc pl-5",
  number: "list-decimal pl-5",
  plain: "list-none pl-0",
} as const satisfies Record<CustomizationMarkerStyle, string>;

function getMarkerClass(markerStyle: CustomizationMarkerStyle) {
  if (markerStyle === "number") {
    return markerClassByStyle.number;
  }

  if (markerStyle === "bullet") {
    return markerClassByStyle.bullet;
  }

  if (markerStyle === "plain") {
    return markerClassByStyle.plain;
  }

  return markerClassByStyle.plain;
}
---

<section class="bg-white pb-14 md:pb-20">
  <Container class="!max-w-[1280px]">
    <h2 class="text-center text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      Customization Options
    </h2>

    {
      groups.map((group, index) => (
        <section class={index === 0 ? "mt-4 md:mt-5" : "mt-14 md:mt-16"}>
          <h3 class="text-lg font-extrabold text-ink md:text-2xl">
            {group.title}
          </h3>

          {group.images?.length ? (
            <div class="mt-7 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {group.images.map((item) => (
                <figure class="overflow-hidden bg-surface-muted">
                  <div class="aspect-[1.45]">
                    <SanityImage
                      image={item}
                      class="size-full object-cover"
                      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    />
                  </div>
                </figure>
              ))}
            </div>
          ) : null}

          <div class="mt-9">
            {group.intro && (
              <p class="text-sm leading-6 text-text-muted md:text-[15px] md:leading-7">
                {group.intro}
              </p>
            )}
            <div class="mt-5 grid gap-7 text-sm leading-6 text-text-muted md:text-[15px] md:leading-7">
              {group.blocks.map((block) => {
                if (block._type === "paragraphBlock") {
                  return (
                    <p>{block.text}</p>
                  );
                }

                if (block._type === "listBlock") {
                  return (
                    <section class="grid gap-2">
                      {block.title && <h4 class="text-base font-extrabold text-ink">{block.title}</h4>}
                      <ul class={`grid gap-2 ${getMarkerClass(block.markerStyle)}`}>
                        {block.items.map((item) => <li>{item}</li>)}
                      </ul>
                      {block.note && <p>{block.note}</p>}
                    </section>
                  );
                }

                if (block._type === "entryListBlock") {
                  return (
                    <section class="grid gap-4">
                      {block.title && <h4 class="text-base font-extrabold text-ink">{block.title}</h4>}
                      <ul class={`grid gap-4 ${getMarkerClass(block.markerStyle)}`}>
                        {block.entries.map((entry) => (
                          <li class="space-y-3">
                            {entry.title && <p class="font-extrabold text-ink">{entry.title}</p>}
                            {entry.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}
                            {entry.detailGroups?.map((detailGroup) => (
                              <div class="space-y-2">
                                {detailGroup.label && <p class="font-semibold text-ink">{detailGroup.label}</p>}
                                <ul class={`grid gap-2 ${getMarkerClass(detailGroup.markerStyle)}`}>
                                  {detailGroup.items.map((item) => <li>{item}</li>)}
                                </ul>
                                {detailGroup.note && <p>{detailGroup.note}</p>}
                              </div>
                            ))}
                            {entry.note && <p>{entry.note}</p>}
                          </li>
                        ))}
                      </ul>
                    </section>
                  );
                }

                return null;
              })}
            </div>
          </div>
        </section>
      ))
    }
  </Container>
</section>
