---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCard, ProductCustomizationGroup } from "../../../data/products";

interface Props {
  title?: string;
  materials?: ProductCard[];
  highlights?: string[];
  groups?: ProductCustomizationGroup[];
}

const { materials = [], highlights = [], groups = [] } = Astro.props;
const visualCards = materials.slice(0, 3).map((item) => item.image);
const customizationGroups = groups.length
  ? groups
  : [
      {
        title: "Materials",
        intro:
          "Match material, color, size, print technique, finish, and packing method across your product line.",
        images: visualCards,
        blocks: [
          {
            title: "Available Custom Options",
            items: highlights,
          },
        ],
      },
    ];
---

<section class="bg-white pb-14 md:pb-20">
  <Container class="!max-w-[1120px]">
    <h2 class="text-center text-2xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      Customization Options
    </h2>

    {
      customizationGroups.map((group, index) => (
        <section class={index === 0 ? "mt-4 md:mt-5" : "mt-14 md:mt-16"}>
          <h3 class="text-lg font-extrabold text-ink md:text-2xl">
            {group.title}
          </h3>

          {group.images?.length ? (
            <div class="mt-7 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {group.images.map((item) => (
                <figure class="overflow-hidden bg-surface-muted">
                  <div class="aspect-[1.45]">
                    <SanityImage
                      image={item}
                      class="size-full object-cover"
                      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    />
                  </div>
                </figure>
              ))}
            </div>
          ) : null}

          <div class="mt-9">
            {group.intro && (
              <p class="text-sm leading-6 text-text-muted md:text-[15px] md:leading-7">
                {group.intro}
              </p>
            )}
            <div class="mt-5 grid gap-7 text-sm leading-6 text-text-muted md:text-[15px] md:leading-7">
              {group.blocks.map((block) => (
                <section>
                  <h4 class="text-base font-extrabold text-ink">{block.title}</h4>
                  <ul class="mt-2 grid gap-2">
                    {block.items.map((item) => <li>{item}</li>)}
                  </ul>
                </section>
              ))}
            </div>
          </div>
        </section>
      ))
    }
  </Container>
</section>
