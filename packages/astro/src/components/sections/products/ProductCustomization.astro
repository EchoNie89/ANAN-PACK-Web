---
import Container from "../../ui/Container.astro";
import SanityImage from "../../ui/SanityImage.astro";
import type { ProductCustomizationGroup } from "../../../data/products";
import type { CustomizationMarkerStyle } from "../../../lib/customization-content";

interface Props {
  groups?: ProductCustomizationGroup[];
}

const { groups = [] } = Astro.props;

const markerClassByStyle = {
  bullet: "list-disc pl-5",
  number: "list-decimal pl-5",
  plain: "list-none pl-0",
} as const satisfies Record<CustomizationMarkerStyle, string>;

function getMarkerClass(markerStyle: CustomizationMarkerStyle) {
  if (markerStyle === "number") {
    return markerClassByStyle.number;
  }

  if (markerStyle === "bullet") {
    return markerClassByStyle.bullet;
  }

  if (markerStyle === "plain") {
    return markerClassByStyle.plain;
  }

  return markerClassByStyle.plain;
}
---

<section class="bg-white pb-14 md:pb-20">
  <Container class="!max-w-[1280px]">
    <h2 class="text-center text-2xl font-extrabold leading-tight tracking-[0.01em] text-text-main md:text-[32px]">
      Customization Options
    </h2>

    {
      groups.map((group, index) => (
        <section class={index === 0 ? "mt-3 md:mt-4" : "mt-12 md:mt-14"}>
          <h3 class="text-[20px] font-semibold leading-tight text-text-main md:text-[24px]">
            {group.title}
          </h3>

          {group.images?.length ? (
            <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
              {group.images.map((item) => (
                <figure class="overflow-hidden bg-surface-muted">
                  <div class="aspect-[1.45]">
                    <SanityImage
                      image={item}
                      class="size-full object-cover"
                      sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    />
                  </div>
                </figure>
              ))}
            </div>
          ) : null}

          <div class="mt-7">
            {group.intro && (
              <p class="whitespace-pre-line text-sm leading-[24px] text-text-main md:text-[15px] md:leading-[25px]">
                {group.intro}
              </p>
            )}
            <div class="mt-4 grid gap-5 text-sm leading-[24px] text-text-main md:text-[15px] md:leading-[25px]">
              {group.blocks.map((block) => {
                if (block._type === "paragraphBlock") {
                  return (
                    <p>{block.text}</p>
                  );
                }

                if (block._type === "listBlock") {
                  const listItems = (block.items ?? []).filter((item) => item.trim().length > 0);

                  return (
                    <section class="grid gap-1.5">
                      {block.title && <h4 class="text-base font-semibold text-text-main">{block.title}</h4>}
                      {block.intro && <p class="whitespace-pre-line">{block.intro}</p>}
                      {listItems.length > 0 && (
                        <ul class={`grid gap-1.5 ${getMarkerClass(block.markerStyle)}`}>
                          {listItems.map((item) => <li>{item}</li>)}
                        </ul>
                      )}
                      {block.note && <p class="whitespace-pre-line">{block.note}</p>}
                    </section>
                  );
                }

                return null;
              })}
            </div>
          </div>
        </section>
      ))
    }
  </Container>
</section>
