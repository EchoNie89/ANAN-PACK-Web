---
import Container from "../../ui/Container.astro";
import { labelWhyItems } from "../../../data/labelsProduct";
---

<section class="bg-white py-16 md:py-20">
  <Container class="!max-w-[1120px]">
    <h2 class="text-center text-xl font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
      Why Choose Us For Your Custom Clothing Labels?
    </h2>

    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        labelWhyItems.map((item) => (
          <article class="grid gap-4">
            <div class="aspect-[4/3] overflow-hidden bg-surface-muted">
              <img src={item.image} alt={item.alt} class="size-full object-cover" loading="lazy" decoding="async" />
            </div>
            <div>
              <h3 class="text-base font-extrabold text-ink">{item.title}</h3>
              <p class="mt-3 text-sm leading-6 text-text-muted">{item.description}</p>
            </div>
          </article>
        ))
      }
    </div>
  </Container>
</section>
