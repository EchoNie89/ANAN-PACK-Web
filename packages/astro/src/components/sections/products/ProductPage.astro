---
import PageCTA from "../PageCTA.astro";
import {
  defaultProductWhyChoose,
  type ProductImage,
  type ProductPageData,
  type ProductShowcaseGroup,
} from "../../../data/products";
import {
  getProductApplications,
  getProductCustomization,
  getProductShowcase,
  sanityImageUrl,
  type SanityImageSource,
} from "../../../lib/sanity";
import ProductApplications from "./ProductApplications.astro";
import ProductCaseStudy from "./ProductCaseStudy.astro";
import ProductCustomization from "./ProductCustomization.astro";
import ProductFaq from "./ProductFaq.astro";
import ProductFeatureBand from "./ProductFeatureBand.astro";
import ProductGalleryMatrix from "./ProductGalleryMatrix.astro";
import ProductHero from "./ProductHero.astro";
import ProductIntro from "./ProductIntro.astro";
import ProductProcess from "./ProductProcess.astro";
import ProductWhyChoose from "./ProductWhyChoose.astro";

interface Props {
  page: ProductPageData;
}

const { page } = Astro.props;
const enableLocalProductFallback =
  import.meta.env.PUBLIC_PRODUCTS_ENABLE_LOCAL_FALLBACK?.trim().toLowerCase() !== "false";

function mapSanityImage(source: SanityImageSource, alt: string, sanityKey: string): ProductImage {
  return {
    src: sanityImageUrl(source).width(1600).auto("format").fit("max").url(),
    alt,
    sanityKey,
    sanitySource: source,
    width: source.dimensions?.width,
    height: source.dimensions?.height,
  };
}

const sanityShowcase = await getProductShowcase(page.slug).catch(() => null);
const sanityShowcaseGroups = sanityShowcase?.showcaseGroups
  ?.map((group, groupIndex) => ({
    title: group.title,
    description: group.description,
    cards: group.cards
      .filter((card) => card.image)
      .map((card, cardIndex) => ({
        title: card.title,
        description: card.description,
        image: mapSanityImage(
          card.image,
          card.alt ?? card.title,
          `sanity.products.${page.slug}.showcase.${groupIndex}.${cardIndex}`,
        ),
      })),
  }))
  .filter((group) => group.cards.length) satisfies ProductShowcaseGroup[] | undefined;

const showcaseGroups = sanityShowcaseGroups?.length
  ? sanityShowcaseGroups
  : enableLocalProductFallback
    ? page.showcaseGroups
    : [];

const sanityApplicationsData = await getProductApplications(page.slug).catch(() => null);
const sanityApplications = sanityApplicationsData?.applications
  ?.filter((card) => card.image)
  .map((card, cardIndex) => ({
    title: card.title,
    description: card.description,
    image: mapSanityImage(
      card.image,
      card.alt ?? card.title,
      `sanity.products.${page.slug}.applications.${cardIndex}`,
    ),
  }));

const applicationTitle = sanityApplicationsData?.applicationTitle
  ?? (enableLocalProductFallback ? page.applicationTitle : undefined);
const applicationDescription = sanityApplicationsData?.applicationDescription
  ?? (enableLocalProductFallback ? page.applicationDescription : undefined);
const applications = sanityApplications?.length
  ? sanityApplications
  : enableLocalProductFallback
    ? page.applications
    : [];

const sanityCustomizationData = await getProductCustomization(page.slug).catch(() => null);
const sanityCustomizationGroups = sanityCustomizationData?.customizationGroups
  ?.filter((group) => group.blocks?.length)
  .map((group, groupIndex) => ({
    title: group.title,
    intro: group.intro,
    images: (group.images || [])
      .filter((img) => img.image?.asset?._ref)
      .map((img, imgIndex) =>
        mapSanityImage(
          img.image,
          img.alt ?? group.title,
          `sanity.products.${page.slug}.customization.${groupIndex}.${imgIndex}`,
        )
      ),
    blocks: group.blocks,
  }));
const customizationGroups = sanityCustomizationGroups?.length
  ? sanityCustomizationGroups
  : enableLocalProductFallback
    ? page.customizationGroups
    : [];
const introHeading = page.introTitle ?? `What Are Custom ${page.navLabel}?`;
const whyChooseItems = page.whyChoose?.length
  ? page.whyChoose
  : enableLocalProductFallback
    ? defaultProductWhyChoose
    : [];
const cta = page.cta ?? (enableLocalProductFallback
  ? {
      title: "Ready to Upgrade Your Brand's Packaging?",
      description: "Send us your design, get a quote within 6 hours.",
      href: "/contact-us",
      buttonLabel: "Request A Quote  ->",
      note: "We'll reply within 6 hours.",
    }
  : undefined);
const hasOverview = Boolean(page.overview.trim());
const hasFeatureBand = Boolean(page.featureBand?.length);
const hasShowcase = Boolean(showcaseGroups?.some((group) => group.cards.length));
const hasApplications = applications.length > 0;
const hasCustomization = Boolean(customizationGroups?.length);
const hasProcess = page.process.length > 0;
const hasWhyChoose = whyChooseItems.length > 0;
const hasCaseStudy = Boolean(
  page.caseStudy.title.trim()
  || page.caseStudy.description.trim()
  || page.caseStudy.bullets.length
  || page.caseStudy.resultPoints?.length
  || page.caseStudy.quote?.trim()
  || page.caseStudy.challenge?.trim()
  || page.caseStudy.solutionIntro?.trim()
  || page.caseStudy.solutionPoints?.length
  || page.caseStudy.gallery?.length,
);
const hasFaqs = page.faqs.length > 0;
---

<main id="main-content" tabindex="-1">
  <ProductHero
    title={page.title}
    subtitle={page.subtitle}
    navLabel={page.navLabel}
    heroTone={page.heroTone}
    heroAlign={page.heroAlign}
    heroOverlay={page.heroOverlay}
    heroButtonPlacement={page.heroButtonPlacement}
    heroTitleLines={page.heroTitleLines}
    heroImage={page.heroImage}
  />
  {hasFeatureBand && <ProductFeatureBand features={page.featureBand} />}
  {hasOverview && <ProductIntro heading={introHeading} overview={page.overview} />}
  {hasShowcase && (
    <ProductGalleryMatrix
      navLabel={page.navLabel}
      categories={page.categories}
      materials={page.materials}
      showcaseGroups={showcaseGroups}
    />
  )}
  {hasApplications && (
    <ProductApplications
      title={applicationTitle}
      description={applicationDescription}
      applications={applications}
      layout={page.applicationLayout}
    />
  )}
  {hasCustomization && (
    <ProductCustomization
      groups={customizationGroups}
    />
  )}
  {hasProcess && <ProductProcess process={page.process} subtitle={page.processSubtitle} />}
  {hasWhyChoose && (
    <ProductWhyChoose
      title={page.whyChooseTitle ?? `Why Choose Us For Custom ${page.navLabel}?`}
      items={whyChooseItems}
    />
  )}
  {hasCaseStudy && <ProductCaseStudy caseStudy={page.caseStudy} />}
  {hasFaqs && <ProductFaq faqs={page.faqs} />}
  {cta && (
    <PageCTA
      title={cta.title}
      description={cta.description}
      href={cta.href}
      buttonLabel={cta.buttonLabel}
      note={cta.note}
      tone="tan"
      class="bg-surface"
    />
  )}
</main>
