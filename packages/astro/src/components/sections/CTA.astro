---
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import SymbolIcon from '../ui/SymbolIcon.astro';
---

<section id="contact" class="bg-white pb-16">
  <Container>
    <div class="rounded-[6px] bg-[#E6DBCA] px-6 py-8 md:px-10 md:py-9">
      <div
        class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between"
      >
        <div class="max-w-2xl">
          <h2 class="text-2xl font-black text-ink">
            Need Packaging & Trim Solutions For Your Brand?
          </h2>
          <p class="mt-3 text-sm leading-6 text-text-main">
            From low-MOQ hangtags to complete trim kits, our sourcing team can
            turn your packaging ideas into production-ready samples.
          </p>
        </div>
        <div class="flex flex-col items-start gap-3 md:items-end">
          <Button href="/contact-us#project-form" variant="dark"
            >Request a Quote</Button
          >
          <p class="inline-flex items-center gap-2 text-xs text-text-muted">
            <SymbolIcon name="clock" class="size-4" />
            We'll reply within 6 hours.
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>
