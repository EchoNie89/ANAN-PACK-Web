---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
---

<section id="contact" class="bg-white pb-16">
  <Container>
    <div class="rounded-panel bg-[#deceb5] px-6 py-8 md:px-10 md:py-9">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-extrabold text-ink">
            Need Packaging & Trim Solutions For Your Brand?
          </h2>
          <p class="mt-3 text-sm leading-6 text-text-main">
            From low-MOQ hangtags to complete trim kits, our sourcing team can turn your packaging ideas into production-ready samples.
          </p>
        </div>
        <Button href="mailto:hello@example.com" variant="dark">Request a Quote</Button>
      </div>
    </div>
  </Container>
</section>
