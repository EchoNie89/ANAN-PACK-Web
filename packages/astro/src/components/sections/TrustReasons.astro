---
import Container from '../ui/Container.astro';
import LocalImage from '../ui/LocalImage.astro';
import { trustReasons, certifications, logos } from '../../data/home';
import { getLocalImage } from '../../lib/local-images';

const trustImage = getLocalImage('/images/home/trust-qc.png');
const trustHeadingLines = ['We Manage the Risk.', 'You Build the Brand'];
---

<section id="trust" class="bg-[#f9f9f9] py-16 md:py-20">
  <Container class="!max-w-[1248px]">
    <h2
      class="text-center text-[32px] font-extrabold tracking-[-0.03em] text-[#333333] md:text-[36px]"
    >
      Why Trust Us?
    </h2>

    <div
      class="mt-10 rounded-[28px] bg-white p-4 shadow-[0_18px_55px_rgba(35,29,20,0.08)] md:mt-12 md:p-7 lg:p-8"
    >
      <div
        class="grid gap-7 lg:grid-cols-[minmax(0,624px)_minmax(0,1fr)] lg:items-center lg:gap-10"
      >
        <div class="overflow-hidden rounded-[20px] bg-[#f1ece5]">
          <LocalImage
            src={trustImage}
            alt="Quality control inspection for custom hang tags"
            class="aspect-[624/577] size-full object-cover"
            loading="lazy"
            sizes="(min-width: 1280px) 624px, 100vw"
            widths={[480, 720, 960, 1280]}
          />
        </div>

        <div class="flex flex-col justify-center lg:pr-4">
          <h3
            class="max-w-[390px] text-[2.125rem] font-bold leading-[1.14] tracking-[-0.03em] text-[#333333] md:text-[2.5rem] lg:text-[32px]"
          >
            {trustHeadingLines.map((line) => <span class="block">{line}</span>)}
          </h3>

          <div class="mt-7 md:mt-8">
            {
              trustReasons.map((item, index) => (
                <article
                  class:list={[
                    "flex items-start gap-4 py-6 md:gap-5 md:py-7",
                    index > 0 && "border-t border-[#ebe5dd]",
                  ]}
                >
                  <div
                    class="flex size-20 shrink-0 items-center justify-center rounded-full bg-[#f8f4ed] ring-1 ring-[#f1e9df]"
                    aria-hidden="true"
                  >
                    <LocalImage
                      src={item.icon.src}
                      alt={item.icon.alt}
                      aria-hidden="true"
                      class="size-[54px] object-contain"
                      loading="lazy"
                      width={80}
                      height={80}
                    />
                  </div>
                  <div class="flex-1">
                    <h4
                      class="text-[1.85rem] font-medium italic leading-[1.08] tracking-[-0.02em] text-[#333333] md:text-[2rem] lg:text-[24px]"
                    >
                      {item.title}
                    </h4>
                    <p
                      class="mt-3 max-w-[33ch] text-base leading-[1.6] text-[#666666] lg:text-[15px]"
                    >
                      {item.description}
                    </p>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-10 rounded-[28px] bg-white px-4 py-8 shadow-[0_18px_55px_rgba(35,29,20,0.08)] md:mt-12 md:px-8 md:py-10"
    >
      <h3
        class="text-center text-[32px] font-bold tracking-[-0.03em] text-[#000000] md:text-[36px]"
      >
        Trusted By
      </h3>
      <div class="mt-8 overflow-x-auto pb-2 md:mt-10 md:pb-0">
        <div class="flex min-w-max items-center gap-5 px-6 md:min-w-0 md:justify-between md:gap-6 md:px-8">
          {logos.map((logo, index) => (
            <div class="flex h-[82px] w-[124px] shrink-0 items-center justify-center">
              <LocalImage
                src={logo}
                alt={`Partner logo ${index + 1}`}
                class="max-h-[82px] max-w-[112px] object-contain grayscale"
                loading="lazy"
                sizes="124px"
                widths={[124, 248]}
              />
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-[28px] bg-[#f2ede5] px-4 py-8 md:mt-10 md:px-7 md:py-10">
      <h3
        class="text-center text-[32px] font-bold tracking-[-0.03em] text-[#000000] md:text-[36px]"
      >
        Certified Materials & Standards
      </h3>
      <div class="mt-8 overflow-x-auto pb-2 md:mt-10 md:pb-0">
        <div class="flex min-w-max gap-4 md:grid md:min-w-0 md:grid-cols-4 md:gap-4 lg:gap-5">
          {
            certifications.map((cert) => (
              <article
                class="flex h-[233px] w-[224px] shrink-0 flex-col items-center justify-center rounded-[14px] bg-white px-5 text-center shadow-[0_10px_30px_rgba(35,29,20,0.05)] md:h-[240px] md:w-auto"
              >
                <LocalImage
                  src={cert.image}
                  alt={cert.alt}
                  class="mx-auto h-auto max-h-[148px] w-auto max-w-[188px] object-contain md:max-h-[150px] md:max-w-[180px]"
                  loading="lazy"
                  sizes="200px"
                  widths={[160, 200, 320]}
                />
                <h3 class="mt-4 text-[14px] font-medium text-[#666666]">
                  {cert.title}
                </h3>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </Container>
</section>
