---
import Container from "../ui/Container.astro";
import LocalImage from "../ui/LocalImage.astro";
import { getLocalImage } from "../../lib/local-images";

const caseStudyImage = getLocalImage("/images/home/case-study.png");
---

<section id="case-study" class="bg-white py-14 md:py-20">
  <Container class="!max-w-[1280px]">
    <div class="grid gap-8 md:gap-10 lg:grid-cols-[minmax(0,531px)_minmax(0,609px)] lg:justify-between lg:gap-[60px]">
      <div class="overflow-hidden bg-surface-muted">
        <LocalImage
          src={caseStudyImage}
          alt="Kalisa integrated packaging case study set"
          class="aspect-[531/545] size-full object-cover"
          loading="lazy"
          sizes="(min-width: 1024px) 50vw, 100vw"
          widths={[480, 720, 960, 1280]}
        />
      </div>

      <div>
        <h2 class="text-[30px] font-extrabold tracking-[0.03em] text-text-main md:text-[32px]">
          Case Study
        </h2>
        <h3 class="mt-4 max-w-[609px] text-[22px] font-bold leading-[1.5] text-text-main md:text-[24px]">
          Exploring how we create customized packaging solutions for brands.
        </h3>
        <p class="mt-5 max-w-[605px] text-[15px] leading-[1.5] text-text-muted text-justify">
          For the luxury apparel brand Kalisa, we delivered a fully integrated accessory solution from embossed hangtags and high-density woven labels to branded tissue paper and stickers. This unified black-and-white system elevated the brand's premium identity and reduced vendor management time by 30%.
        </p>

        <div class="mt-10 max-w-[608px]">
          <div class="text-[68px] font-extrabold leading-none text-text-main md:text-[80px]">“</div>
          <blockquote class="-mt-3 text-[14px] italic leading-[22px] text-text-muted text-justify">
            Their one-stop service transformed our fragmented supply chain into a seamless process. The consistent quality and cohesive visual language boosted our customer's perception of luxury.
          </blockquote>
          <p class="mt-6 text-[15px] font-bold italic leading-[22px] text-text-main">Kalisa Brand Director, USA</p>
        </div>

        <div class="mt-10">
          <a
            href="/about-us"
            class="inline-flex h-[50px] w-[180px] items-center justify-center rounded-[200px] bg-[#E6DBCB] text-[18px] font-semibold leading-none text-text-main transition hover:bg-[#d9c7af] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
          >
            View More
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
