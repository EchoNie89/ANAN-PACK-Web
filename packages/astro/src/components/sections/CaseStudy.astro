---
import Container from "../ui/Container.astro";
import LocalImage from "../ui/LocalImage.astro";
import SymbolIcon from "../ui/SymbolIcon.astro";
import { getLocalImage } from "../../lib/local-images";

const caseStudyImage = getLocalImage("/images/home/case-study.png");
const caseStudyQuote = getLocalImage("/images/home/case-study-quote.png");
---

<section id="case-study" class="bg-white py-14 md:py-20">
  <Container class="!max-w-[1280px]">
    <div class="grid items-start gap-8 md:gap-10 lg:grid-cols-[minmax(0,562px)_minmax(0,609px)] lg:justify-between lg:gap-[47px]">
      <div class="overflow-hidden rounded-soft bg-surface-muted" data-reveal>
        <LocalImage
          src={caseStudyImage}
          alt="Kalisa integrated packaging case study set"
          class="aspect-[562/486] size-full object-cover"
          loading="lazy"
          sizes="(min-width: 1024px) 50vw, 100vw"
          widths={[480, 720, 960, 1280]}
        />
      </div>

      <div class="flex flex-col items-start gap-5" data-reveal style="--reveal-delay: 100ms;">
        <p class="text-[14px] font-extrabold uppercase tracking-[0.03em] text-[#A67237]">
          Case Study
        </p>
        <div class="h-px w-10 bg-[#A67237]"></div>
        <h2 class="max-w-[609px] text-[30px] font-extrabold leading-[1.15] text-text-main md:text-[32px] md:leading-[36px]">
          Exploring how we create customized packaging solutions for brands.
        </h2>
        <p class="max-w-[609px] text-[15px] font-medium leading-[1.5] text-text-main text-justify">
          For the luxury apparel brand Kalisa, we delivered a fully integrated accessory solution from embossed hangtags and high-density woven labels to branded tissue paper and stickers. This unified, minimalist black-and-white system elevated the brand's premium identity and reduced their vendor management time by 30%.
        </p>

        <div class="relative min-h-[132px] w-full max-w-[609px] rounded-soft bg-[#F6F4EF] md:h-[132px]">
          <div class="absolute left-5 top-3" aria-hidden="true">
            <LocalImage
              src={caseStudyQuote}
              alt=""
              aria-hidden="true"
              class="h-[22px] w-[28px]"
              loading="eager"
              width={28}
              height={22}
            />
          </div>
          <blockquote class="pl-[56px] pr-5 pt-3 pb-14 text-[14px] italic leading-[22px] text-text-muted text-justify md:absolute md:inset-[12px_51px_54px_69px] md:px-0 md:pb-0 md:pt-0">
            Their one-stop service transformed our fragmented supply chain into a seamless process. The consistent quality and cohesive visual language boosted our customer's perception of luxury.
          </blockquote>
          <p class="pl-[56px] pr-5 pb-4 text-[15px] font-bold italic leading-[22px] text-text-main md:absolute md:bottom-3 md:left-[69px] md:px-0 md:pb-0">
            Kalisa Brand Director, USA
          </p>
        </div>

        <div>
          <a
            href="/blog"
            class="inline-flex h-[50px] w-full max-w-[300px] items-center justify-center rounded-soft bg-[#E6DBCB] px-6 text-center text-[18px] font-semibold leading-none text-text-main transition hover:bg-[#d9c7af] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 md:w-[300px]"
          >
            View More Case Studies
            <SymbolIcon name="arrowLongRight" class="ml-2 size-3" />
          </a>
        </div>
      </div>
    </div>
  </Container>
</section>
