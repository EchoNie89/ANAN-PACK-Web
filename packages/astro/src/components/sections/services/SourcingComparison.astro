---
import Container from "../../ui/Container.astro";
import { sourcingComparison } from "../../../data/services";

const columns = [
  { ...sourcingComparison.traditional, tone: "muted", label: "" },
  { ...sourcingComparison.managed, tone: "brand" },
] as const;
---

<section class="bg-[#f5f6fa] py-16 md:py-20">
  <Container class="lg:!max-w-[1200px]">
    <h2 class="text-center text-2xl font-extrabold text-ink md:text-3xl" data-reveal>
      {sourcingComparison.title}
    </h2>

    <div class="mt-12 grid gap-5 lg:grid-cols-2">
      {
        columns.map((column, index) => (
          <article
            class={`motion-hover-card relative overflow-hidden rounded-md border bg-white p-6 md:p-8 ${
              column.tone === "brand" ? "border-[#d4aa77]" : "border-[#e5e5e5]"
            }`}
            data-reveal
            style={`--reveal-delay: ${index * 90}ms;`}
          >
            {column.tone === "brand" && (
              <span class="absolute right-0 top-0 bg-nav-active px-5 py-2 text-xs font-bold text-white">
                {column.label}
              </span>
            )}
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-xl font-extrabold text-ink md:text-2xl">{column.title}</h3>
                <p
                  class={`mt-4 inline-flex rounded px-4 py-2 text-xs font-semibold ${
                    column.tone === "brand"
                      ? "bg-brand-soft text-brand-dark"
                      : "bg-[#f4f4f4] text-text-muted"
                  }`}
                >
                  {column.tag}
                </p>
              </div>
              {column.tone === "brand" && (
                <div class="hidden size-16 shrink-0 items-center justify-center rounded-full bg-[#fbf2e5] text-brand sm:flex">
                  <svg viewBox="0 0 24 24" class="size-8" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                    <path d="M6 15.5V18a2 2 0 0 0 2 2h8.5" />
                    <path d="M18 10.5V8a2 2 0 0 0-2-2H7.5" />
                    <path d="m15 8 3-3 3 3" />
                    <path d="m9 16-3 3-3-3" />
                    <path d="M10 9.5h4" />
                    <path d="M10 13.5h4" />
                  </svg>
                </div>
              )}
            </div>

            <div class="mt-6 h-px bg-[#e6e1da]"></div>

            <ul class="mt-6 grid gap-4 text-sm leading-5 text-text-main">
              {column.points.map((point) => (
                <li class="flex items-start gap-3">
                  <span
                    class={`mt-0.5 inline-flex size-4 shrink-0 items-center justify-center rounded-full text-[10px] ${
                      column.tone === "brand" ? "text-brand" : "text-[#c87232]"
                    }`}
                    aria-hidden="true"
                  >
                    {column.tone === "brand" ? (
                      <svg viewBox="0 0 16 16" class="size-4" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m3.5 8.2 2.7 2.7 6.3-6.6" />
                      </svg>
                    ) : (
                      <svg viewBox="0 0 16 16" class="size-4" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m4 4 8 8" />
                        <path d="m12 4-8 8" />
                      </svg>
                    )}
                  </span>
                  <span>{point}</span>
                </li>
              ))}
            </ul>

            <p
              class={`-mx-6 -mb-6 mt-8 px-6 py-5 text-center text-sm font-semibold md:-mx-8 md:-mb-8 ${
                column.tone === "brand" ? "bg-[#fff1dd] text-brand-dark" : "bg-[#f3f3f3] text-text-muted"
              }`}
            >
              {column.summary}
            </p>
          </article>
        ))
      }
    </div>

    <div
      class="mt-8 flex items-center justify-center gap-3 bg-[#fbf1df] px-4 py-5 text-center text-sm font-semibold text-text-main"
      data-reveal
      style="--reveal-delay: 120ms;"
    >
      <span class="inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-brand-dark text-white" aria-hidden="true">
        <svg viewBox="0 0 20 20" class="size-5" fill="none" stroke="currentColor" stroke-width="1.8">
          <path d="M10 4v12" />
          <path d="M4 10h12" />
        </svg>
      </span>
      <p>{sourcingComparison.note}</p>
    </div>
  </Container>
</section>
