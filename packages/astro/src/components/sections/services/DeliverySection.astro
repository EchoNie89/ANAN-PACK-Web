---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { delivery } from "../../../data/services";
import { getLocalImage } from "../../../lib/local-images";

const deliveryBackdrop = getLocalImage("/images/services/delivery-bg.png");
---

<section class="relative isolate overflow-hidden bg-[#f6f6f6] py-16 md:py-20">
  <LocalImage
    src={deliveryBackdrop}
    alt=""
    class="pointer-events-none absolute bottom-28 left-1/2 z-0 w-full max-w-5xl -translate-x-1/2 opacity-30"
    loading="lazy"
    sizes="100vw"
    widths={[640, 960, 1280, 1600]}
  />
  <Container class="relative z-10 lg:!max-w-[1280px]">
    <div class="mx-auto max-w-5xl text-center" data-reveal>
      <h2 class="text-3xl font-extrabold text-ink md:text-4xl">{delivery.title}</h2>
      <p class="mt-8 text-xl font-bold capitalize leading-8 text-text-muted md:text-2xl">
        {delivery.subtitle}
      </p>
    </div>

    <div
      class="mx-auto mt-10 max-w-[1280px] space-y-6 text-sm leading-7 text-text-muted"
      data-reveal
      style="--reveal-delay: 100ms;"
    >
      {delivery.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>

    <div
      class="mt-10 grid grid-cols-2 items-center gap-6 sm:grid-cols-3 lg:grid-cols-6"
      data-reveal
      style="--reveal-delay: 180ms;"
    >
      {
        delivery.partners.map((partner) => (
          <div class="flex h-16 items-center justify-center">
            <LocalImage
              src={partner.image}
              alt={`${partner.name} logistics partner logo`}
              class="max-h-12 max-w-[130px] object-contain"
              loading="lazy"
              sizes="130px"
              widths={[130, 260, 390]}
            />
          </div>
        ))
      }
    </div>
  </Container>
</section>
