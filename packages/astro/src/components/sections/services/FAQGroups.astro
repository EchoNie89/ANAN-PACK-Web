---
import Button from '../../ui/Button.astro';
import Container from '../../ui/Container.astro';
import { faqGroups } from '../../../data/services';
---

<section class="bg-white py-16 md:py-20">
  <Container class="space-y-16 lg:!max-w-[1200px]">
    {
      faqGroups.map((group, index) => (
        <section
          aria-labelledby={group.title
            .toLowerCase()
            .replaceAll(' ', '-')
            .replaceAll(':', '')}
          data-reveal
          style={`--reveal-delay: ${index * 80}ms;`}
        >
          <h2
            id={group.title
              .toLowerCase()
              .replaceAll(' ', '-')
              .replaceAll(':', '')}
            class="text-2xl font-extrabold text-ink md:text-3xl"
          >
            {group.title}
          </h2>

          <div class="mt-8">
            {group.items.map((item, itemIndex) => (
              <details
                class="group border-b border-[#e3e3e3] open:bg-[#fffaf2]"
                open={itemIndex === 0}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between gap-6 rounded-sm py-5 text-base font-extrabold text-black focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2">
                  <span>{item.question}</span>
                  <svg
                    viewBox="0 0 16 16"
                    class="size-4 shrink-0 text-text-muted transition group-open:rotate-180"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M8 11 3.5 5h9z" />
                  </svg>
                </summary>
                <div class="pb-6 pr-10">
                  <p class="max-w-5xl text-sm leading-7 text-text-main">
                    {item.answer}
                  </p>
                </div>
              </details>
            ))}
          </div>
        </section>
      ))
    }
  </Container>
</section>
