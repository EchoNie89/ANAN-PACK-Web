---
import Button from "../../ui/Button.astro";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { serviceHero } from "../../../data/services";
---

<section class="services-hero relative isolate overflow-hidden bg-[#dfe7e9] md:h-[474px]">
  <LocalImage
    src={serviceHero.image}
    alt={serviceHero.alt}
    class="pointer-events-none absolute inset-0 z-0 size-full object-cover"
    loading="eager"
    sizes="100vw"
    widths={[640, 960, 1280, 1600, 1920]}
    priority
  />
  <Container class="relative z-10 flex min-h-[360px] items-center py-16 md:min-h-[474px] lg:h-full lg:min-h-0 lg:!max-w-[1200px]">
    <div class="max-w-3xl pt-3 text-white">
      <nav class="mb-14 flex items-center gap-4 text-sm font-medium text-white/65" aria-label="Breadcrumb">
        <a href="/home" class="transition hover:text-white focus:outline-none focus:ring-2 focus:ring-white/70">Home</a>
        <span aria-hidden="true">&gt;</span>
        <span class="text-white">Services</span>
      </nav>
      <h1 class="font-display text-4xl font-black leading-tight tracking-normal md:text-5xl lg:max-w-[715px]">
        {serviceHero.title}
      </h1>
      <p class="mt-8 max-w-3xl text-base font-medium capitalize leading-7 text-white/95 md:text-xl md:leading-8">
        {serviceHero.description}
      </p>
      <Button href="/home#contact" variant="soft" class="mt-10 px-6 py-3 text-sm normal-case tracking-normal">
        {serviceHero.cta}
      </Button>
    </div>
  </Container>
</section>
