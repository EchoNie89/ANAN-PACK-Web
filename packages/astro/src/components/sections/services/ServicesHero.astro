---
import Button from "../../ui/Button.astro";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { serviceHero } from "../../../data/services";
---

<section class="services-hero relative isolate overflow-hidden bg-[#dfe7e9] md:h-[474px]">
  <LocalImage
    src={serviceHero.image}
    alt={serviceHero.alt}
    class="pointer-events-none absolute inset-0 z-0 size-full object-cover"
    loading="eager"
    sizes="100vw"
    widths={[640, 960, 1280, 1600, 1920]}
    priority
  />
  <Container class="relative z-10 flex min-h-[360px] items-center py-16 md:min-h-[474px] lg:h-full lg:min-h-0 lg:!max-w-[1280px]">
    <div class="max-w-3xl pt-3 text-white">
      <nav
        class="motion-enter mb-14 flex items-center gap-4 text-sm font-medium text-white/65"
        aria-label="Breadcrumb"
        style="--motion-delay: 80ms;"
      >
        <a href="/" class="transition hover:text-white focus:outline-none focus:ring-2 focus:ring-white/70">Home</a>
        <span aria-hidden="true">&gt;</span>
        <span class="text-white">Services</span>
      </nav>
      <h1
        class="motion-enter font-display text-4xl font-black leading-tight tracking-normal md:text-5xl lg:max-w-[715px]"
        style="--motion-delay: 160ms;"
      >
        {serviceHero.title}
      </h1>
      <p
        class="motion-enter mt-8 max-w-3xl text-base font-medium capitalize leading-7 text-white/95 md:text-xl md:leading-8"
        style="--motion-delay: 240ms;"
      >
        {serviceHero.description}
      </p>
      <div class="motion-enter mt-10" style="--motion-delay: 320ms;">
        <Button href="/#contact" variant="soft" class="px-6 py-3 text-sm normal-case tracking-normal">
          {serviceHero.cta}
        </Button>
      </div>
    </div>
  </Container>
</section>
