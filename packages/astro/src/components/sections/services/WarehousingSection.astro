---
import Container from "../../ui/Container.astro";
import { warehousing } from "../../../data/services";
---

<section class="bg-white py-16 md:py-20">
  <Container class="lg:!max-w-[1200px]">
    <h2 class="text-center text-3xl font-extrabold text-ink md:text-4xl">
      {warehousing.title}
    </h2>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        warehousing.cards.map((card) => (
          <article class="text-center">
            <img
              src={card.image}
              alt={card.alt}
              class="h-56 w-full object-cover md:h-48 lg:h-[210px]"
              loading="lazy"
              decoding="async"
            />
            <h3 class="mt-7 text-xl font-extrabold text-ink">{card.title}</h3>
            <p class="mt-5 text-sm leading-6 text-text-muted">{card.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
