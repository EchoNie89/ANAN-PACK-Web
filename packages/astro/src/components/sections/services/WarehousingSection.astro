---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { warehousing } from "../../../data/services";
---

<section class="bg-white py-16 md:py-20">
  <Container class="lg:!max-w-[1280px]">
    <h2 class="text-center text-3xl font-extrabold text-ink md:text-4xl" data-reveal>
      {warehousing.title}
    </h2>

    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        warehousing.cards.map((card, index) => (
          <article
            class="motion-hover-card group text-center"
            data-reveal
            style={`--reveal-delay: ${index * 80}ms;`}
          >
            <div class="overflow-hidden">
              <LocalImage
                src={card.image}
                alt={card.alt}
                class="h-56 w-full object-cover transition duration-500 group-hover:scale-[1.03] md:h-48 lg:h-[210px]"
                loading="lazy"
                sizes="(min-width: 768px) 30vw, 100vw"
                widths={[320, 480, 640, 800]}
              />
            </div>
            <h3 class="mt-7 text-xl font-extrabold text-ink">{card.title}</h3>
            <p class="mt-5 text-sm leading-6 text-text-muted">{card.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
