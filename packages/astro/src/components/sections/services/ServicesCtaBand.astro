---
import Button from "../../ui/Button.astro";
import Container from "../../ui/Container.astro";

interface Props {
  title: string;
  button: string;
  note: string;
}

const { title, button, note } = Astro.props;
---

<section class="bg-white py-16">
  <Container class="lg:!max-w-[1280px]">
    <div
      class="flex flex-col gap-8 bg-[#e6dbcb] px-6 py-10 md:flex-row md:items-center md:justify-between md:px-9"
      data-reveal
    >
      <h2 class="max-w-2xl text-2xl font-extrabold capitalize text-ink md:text-3xl">
        {title}
      </h2>
      <div class="flex flex-col items-start gap-4 md:items-center">
        <Button href="/contact-us#project-form" variant="dark" class="px-8 py-4 text-sm normal-case tracking-normal">
          {button}
        </Button>
        <p class="flex items-center gap-2 text-xs text-text-muted">
          <svg viewBox="0 0 20 20" class="size-4" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="10" cy="10" r="7" />
            <path d="M10 6v4l3 2" />
          </svg>
          {note}
        </p>
      </div>
    </div>
  </Container>
</section>
