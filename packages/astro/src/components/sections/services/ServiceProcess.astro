---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { serviceSections } from "../../../data/services";
---

<section class="bg-white">
  <div class="bg-[#d4c2a4] px-4 py-5 text-center text-base font-medium italic text-text-main md:text-lg" data-reveal>
    One Point Of Contact, Infinite Possibilities.
  </div>

  <Container class="space-y-20 py-16 md:py-20 lg:!max-w-[1280px]">
    {
      serviceSections.map((section, index) => (
        <article
          class="border-b border-[#e9e0d4] pb-16 last:border-b-0 last:pb-0"
          data-reveal
          style={`--reveal-delay: ${index * 70}ms;`}
        >
          <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
            <div class={section.imageSide === "right" ? "lg:order-2" : ""}>
              <LocalImage
                src={section.image}
                alt={section.alt}
                class={`h-72 w-full object-cover sm:h-96 lg:h-full ${
                  section.features.length > 3 ? "lg:min-h-[560px]" : "lg:min-h-[535px]"
                }`}
                loading="lazy"
                sizes="(min-width: 1024px) 52vw, 100vw"
                widths={[480, 720, 960, 1280]}
              />
            </div>

            <div class={section.imageSide === "right" ? "lg:order-1" : ""}>
              <p class="text-sm font-extrabold uppercase text-brand-dark">{section.kicker}</p>
              <h2 class="mt-4 text-3xl font-extrabold text-ink md:text-4xl">{section.title}</h2>
              <p class="mt-5 text-base font-semibold leading-7 text-text-muted">{section.description}</p>

              <div class="mt-8 grid gap-4">
                {section.features.map((feature) => (
                  <div class="motion-hover-card flex gap-5 rounded-md border border-[#d0aa4c]/50 bg-white p-5">
                    <div class="flex size-14 shrink-0 items-center justify-center rounded-full bg-[#fbf2e5] text-brand">
                      <svg viewBox="0 0 24 24" class="size-8" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                        <path d="M4 7.5 12 3l8 4.5v9L12 21l-8-4.5z" />
                        <path d="m4 7.5 8 4.5 8-4.5" />
                        <path d="M12 12v9" />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-base font-bold text-ink">{feature.title}</h3>
                      <p class="mt-2 text-sm leading-6 text-text-muted">{feature.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <p class="mt-8 text-justify text-sm leading-7 text-text-muted md:text-[15px]">
            {section.body}
          </p>
        </article>
      ))
    }
  </Container>
</section>
