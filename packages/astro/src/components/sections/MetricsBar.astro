---
import Container from "../ui/Container.astro";
import StatItem from "../ui/StatItem.astro";
import { metrics } from "../../data/home";
---

<section class="bg-white pb-16 md:pb-20">
  <Container>
    <div class="rounded-card border border-border bg-white px-4 py-5 shadow-card" data-reveal>
      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4 lg:divide-x lg:divide-border">
        {metrics.map((metric) => <StatItem {...metric} />)}
      </div>
    </div>
  </Container>
</section>
