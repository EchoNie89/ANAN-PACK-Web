---
import Container from "../ui/Container.astro";
import Card from "../ui/Card.astro";
import { logos } from "../../data/home";
---

<section class="bg-surface-muted pb-8">
  <Container>
    <Card class="bg-white px-6 py-8">
      <h2 class="text-center text-xl font-extrabold text-ink">Trusted By</h2>
      <div class="mt-8 grid grid-cols-2 items-center gap-x-8 gap-y-6 sm:grid-cols-4 lg:grid-cols-8">
        {
          logos.map((logo, index) => (
            <img
              src={logo}
              alt={`Partner logo ${index + 1}`}
              class="mx-auto max-h-8 max-w-28 object-contain grayscale"
              loading="lazy"
              decoding="async"
            />
          ))
        }
      </div>
    </Card>
  </Container>
</section>
