---
import { getBlogCategory, parsePublishedDate, type BlogArticle } from "../../../lib/blog";
import BlogBodyContent from "./BlogBodyContent.astro";

interface Props {
  article: BlogArticle;
  previousArticle?: BlogArticle;
  nextArticle?: BlogArticle;
}

const { article, previousArticle, nextArticle } = Astro.props;
const categoryLabel = getBlogCategory(article.category)?.label ?? article.category;
---

<article>
  <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-text-muted">
    <span class="font-semibold uppercase tracking-[0.12em] text-brand">
      {categoryLabel}
    </span>
    <span>{parsePublishedDate(article.publishedAt).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</span>
    <span>{article.readTime}</span>
  </div>

  <BlogBodyContent blocks={article.body} />

  <div class="mt-12 flex items-center gap-3">
    <span class="text-sm font-semibold uppercase tracking-[0.12em] text-text-main">Share</span>
    <a href="#" aria-label="Share on Facebook" class="flex size-9 items-center justify-center rounded bg-black/10 text-text-main transition hover:bg-brand hover:text-white">f</a>
    <a href="#" aria-label="Share on Instagram" class="flex size-9 items-center justify-center rounded bg-black/10 text-text-main transition hover:bg-brand hover:text-white">◎</a>
    <a href="#" aria-label="Share on X" class="flex size-9 items-center justify-center rounded bg-black/10 text-text-main transition hover:bg-brand hover:text-white">𝕏</a>
    <a href="#" aria-label="Share on LinkedIn" class="flex size-9 items-center justify-center rounded bg-black/10 text-text-main transition hover:bg-brand hover:text-white">in</a>
  </div>

  <div class="mt-12 flex flex-col gap-4 border-t border-border pt-6 text-sm font-extrabold uppercase tracking-[0.08em] text-ink sm:flex-row sm:items-center sm:justify-between">
    <div>
      {
        previousArticle ? (
          <a href={`/blog/${previousArticle.slug}`} class="inline-flex items-center gap-3 transition hover:text-brand">
            <span aria-hidden="true">←</span>
            <span>Previous Post</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-3 text-text-muted">
            <span aria-hidden="true">←</span>
            <span>Previous Post</span>
          </span>
        )
      }
    </div>
    <div>
      {
        nextArticle ? (
          <a href={`/blog/${nextArticle.slug}`} class="inline-flex items-center gap-3 transition hover:text-brand">
            <span>Next Post</span>
            <span aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-3 text-text-muted">
            <span>Next Post</span>
            <span aria-hidden="true">→</span>
          </span>
        )
      }
    </div>
  </div>
</article>
