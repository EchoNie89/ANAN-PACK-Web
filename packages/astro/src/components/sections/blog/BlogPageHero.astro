---
import Container from "../../ui/Container.astro";
import Breadcrumbs from "../../ui/Breadcrumbs.astro";
import LocalImage from "../../ui/LocalImage.astro";
import type { SiteImageSource } from "../../../lib/local-images";

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  backgroundImage: SiteImageSource;
  breadcrumbs: BreadcrumbItem[];
  align?: "center" | "left";
  breadcrumbsAlign?: "center" | "left";
  eyebrow?: string;
  variant?: "default" | "blog-index";
}

const {
  title,
  description,
  backgroundImage,
  breadcrumbs,
  align = "center",
  breadcrumbsAlign,
  eyebrow,
  variant = "default",
} = Astro.props;

const isCentered = align === "center";
const resolvedBreadcrumbsAlign = breadcrumbsAlign ?? (isCentered ? "center" : "left");
const isBlogIndex = variant === "blog-index";
const hasAfterContentSlot = Astro.slots.has("afterContent");
---

<section class="relative isolate overflow-hidden md:h-[474px]">
  <LocalImage
    src={backgroundImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 size-full object-cover"
    loading="eager"
    sizes="100vw"
    widths={[640, 960, 1280, 1600, 1920]}
    priority
  />
  <div
    class={`absolute inset-0 ${
      isBlogIndex
        ? "bg-[linear-gradient(180deg,rgba(235,230,222,0.75)_0%,rgba(235,230,222,0.55)_34%,rgba(235,230,222,0.18)_72%,rgba(235,230,222,0.05)_100%)] md:bg-[linear-gradient(90deg,rgba(235,230,222,0.82)_0%,rgba(235,230,222,0.55)_34%,rgba(235,230,222,0.15)_62%,rgba(235,230,222,0)_100%)]"
        : isCentered
          ? "bg-[linear-gradient(180deg,rgba(26,20,12,0.16),rgba(26,20,12,0.4))]"
          : "bg-[linear-gradient(90deg,rgba(26,20,12,0.58),rgba(26,20,12,0.18))]"
    }`}
  ></div>

  <Container
    class={`relative !max-w-[1280px] ${
      isBlogIndex
        ? "min-h-[470px] pb-8 pt-6 sm:min-h-[540px] sm:pb-10 sm:pt-8 md:flex md:h-full md:min-h-0 md:flex-col md:pb-10 md:pt-8"
        : "pb-12 pt-28 md:h-full md:pb-16 md:pt-36"
    }`}
  >
    <div class={isBlogIndex ? "text-left" : isCentered ? "mx-auto max-w-3xl text-center" : "max-w-3xl"}>
      <Breadcrumbs
        items={breadcrumbs}
        light
        center={resolvedBreadcrumbsAlign === "center"}
        separator=">"
        class={isBlogIndex ? "text-[13px]" : ""}
      />
    </div>

    <div class={isBlogIndex ? "mx-auto mt-10 max-w-4xl text-center sm:mt-14 lg:mt-14" : isCentered ? "mx-auto max-w-3xl text-center" : "max-w-3xl"}>
      {eyebrow && (
        <p
          class="motion-enter mt-6 text-sm font-semibold uppercase tracking-[0.16em] text-white/80"
          style="--motion-delay: 80ms; --motion-distance: 14px;"
        >
          {eyebrow}
        </p>
      )}
      <h1
        class={`motion-enter font-display text-white ${isBlogIndex ? "text-[2.25rem] font-black leading-[1.02] tracking-[-0.03em] sm:text-[2.5rem] md:text-[52px]" : isCentered ? "mt-5 text-4xl font-extrabold md:text-5xl" : "mt-5 text-4xl font-black md:text-[48px] md:leading-[1.08]"}`}
        style={`--motion-delay: ${eyebrow ? "160ms" : "100ms"}; --motion-distance: 16px;`}
      >
        {title}
      </h1>
      {description && (
        <p
          class={`motion-enter text-white/95 ${
            isBlogIndex
              ? "mx-auto mt-4 max-w-[22rem] text-[1rem] font-medium leading-[1.35] sm:max-w-[30rem] sm:text-[1.125rem] md:max-w-4xl md:text-[20px]"
              : isCentered
                ? "mx-auto mt-4 max-w-2xl text-base leading-7 text-white/85 md:text-lg"
                : "mt-4 max-w-2xl text-base leading-7 text-white/85 md:text-lg"
          }`}
          style={`--motion-delay: ${eyebrow ? "240ms" : "180ms"}; --motion-distance: 16px;`}
        >
          {description}
        </p>
      )}
    </div>

    {
      hasAfterContentSlot && (
        <div class={isBlogIndex ? "mt-12 sm:mt-16 md:mt-auto md:pt-10" : "mt-12"}>
          <slot name="afterContent" />
        </div>
      )
    }
  </Container>
</section>
