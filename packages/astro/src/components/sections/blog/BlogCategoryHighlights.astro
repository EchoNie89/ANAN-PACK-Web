---
import type { BlogCategory } from "../../../lib/blog";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";

interface Props {
  categories: BlogCategory[];
  inHero?: boolean;
}

const { categories, inHero = false } = Astro.props;
---

{
  inHero ? (
    <div class="grid gap-5 md:grid-cols-3 md:gap-8">
      {
        categories.map((category) => (
          <div class="flex flex-col items-center text-center">
            <div class="flex h-[100px] w-[100px] items-center justify-center rounded-full bg-white shadow-[0_4px_20px_rgba(0,0,0,0.08)] md:h-[128px] md:w-[128px]">
              <LocalImage
                src={category.icon}
                alt=""
                aria-hidden="true"
                class="h-auto w-[64px] object-contain md:w-[80px]"
                loading="lazy"
                sizes="95px"
                widths={[95, 190]}
                width={category.icon.width}
                height={category.icon.height}
              />
            </div>
            <h2 class="mt-4 text-[14px] font-semibold leading-6 text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.28)] md:text-[16px]">
              {category.label}
            </h2>
          </div>
        ))
      }
    </div>
  ) : (
    <div class="relative z-10 -mt-[84px] pb-8 md:-mt-[132px] md:pb-14">
      <Container class="!max-w-[1200px]">
        <div class="grid gap-6 md:grid-cols-3 md:gap-10">
          {
            categories.map((category) => (
              <div class="flex flex-col items-center text-center">
                <div class="flex h-[112px] w-[112px] items-center justify-center rounded-full bg-white shadow-[0_4px_20px_rgba(0,0,0,0.08)] md:h-[134px] md:w-[134px]">
                  <LocalImage
                    src={category.icon}
                    alt=""
                    aria-hidden="true"
                    class="h-auto w-[72px] object-contain md:w-[95px]"
                    loading="lazy"
                    sizes="95px"
                    widths={[95, 190]}
                    width={category.icon.width}
                    height={category.icon.height}
                  />
                </div>
                <h2 class="mt-5 text-sm font-medium leading-6 text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.28)] md:text-[15px]">
                  {category.label}
                </h2>
              </div>
            ))
          }
        </div>
      </Container>
    </div>
  )
}
