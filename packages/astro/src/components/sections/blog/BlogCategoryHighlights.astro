---
import type { BlogCategory } from "../../../lib/blog";
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";

interface Props {
  categories: BlogCategory[];
  inHero?: boolean;
}

const { categories, inHero = false } = Astro.props;
---

{
  inHero ? (
    <div class="grid grid-cols-3 gap-2 sm:gap-4 md:gap-6">
      {
        categories.map((category, index) => (
          <div
            class="flex flex-col items-center text-center"
            data-reveal
            style={`--reveal-delay: ${220 + index * 80}ms; --reveal-distance: 14px;`}
          >
            <div class="flex h-[84px] w-[84px] items-center justify-center rounded-full bg-white shadow-[0_4px_20px_rgba(0,0,0,0.08)] sm:h-[96px] sm:w-[96px] md:h-[128px] md:w-[128px]">
              <LocalImage
                src={category.icon}
                alt=""
                aria-hidden="true"
                class="h-auto w-[50px] object-contain sm:w-[56px] md:w-[80px]"
                loading="lazy"
                sizes="95px"
                widths={[95, 190]}
                width={category.icon.width}
                height={category.icon.height}
              />
            </div>
            <h2 class="mt-3 max-w-[94px] text-[12px] font-semibold leading-[1.25] text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.28)] sm:text-[13px] md:mt-4 md:max-w-none md:text-[16px] md:leading-6">
              {category.label}
            </h2>
          </div>
        ))
      }
    </div>
  ) : (
    <div class="relative z-10 -mt-[84px] pb-8 md:-mt-[132px] md:pb-14">
      <Container class="!max-w-[1280px]">
        <div class="grid gap-6 md:grid-cols-3 md:gap-10">
          {
            categories.map((category) => (
              <div class="flex flex-col items-center text-center">
                <div class="flex h-[112px] w-[112px] items-center justify-center rounded-full bg-white shadow-[0_4px_20px_rgba(0,0,0,0.08)] md:h-[134px] md:w-[134px]">
                  <LocalImage
                    src={category.icon}
                    alt=""
                    aria-hidden="true"
                    class="h-auto w-[72px] object-contain md:w-[95px]"
                    loading="lazy"
                    sizes="95px"
                    widths={[95, 190]}
                    width={category.icon.width}
                    height={category.icon.height}
                  />
                </div>
                <h2 class="mt-5 text-sm font-medium leading-6 text-white drop-shadow-[0_1px_3px_rgba(0,0,0,0.28)] md:text-[15px]">
                  {category.label}
                </h2>
              </div>
            ))
          }
        </div>
      </Container>
    </div>
  )
}
