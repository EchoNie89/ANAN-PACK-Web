---
import type { BlogArticle } from "../../../lib/blog";
import Container from "../../ui/Container.astro";
import BlogCard from "../../ui/BlogCard.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  articles: BlogArticle[];
  variant?: "default" | "industry";
  pageSize?: number;
  paginationParam?: string;
  paginationAlign?: "center" | "end";
  paginationLabel?: string;
}

const {
  id,
  title,
  description,
  articles,
  variant = "default",
  pageSize = 6,
  paginationParam = id ? `${id}Page` : undefined,
  paginationAlign = "end",
  paginationLabel = `${title} pagination`,
} = Astro.props;

const isIndustry = variant === "industry";
const totalPages = Math.ceil(articles.length / pageSize);
---

{
  articles.length > 0 && (
    <section
      id={id}
      class={isIndustry ? "pb-10 pt-14 md:pb-12 md:pt-20" : "pb-8 pt-10 md:pb-10 md:pt-14"}
      data-blog-pagination-root={paginationParam}
      data-pagination-param={paginationParam}
      data-pagination-total-pages={totalPages}
      data-pagination-anchor={id ? `#${id}` : undefined}
      data-pagination-align={paginationAlign}
    >
      <Container class="!max-w-[1280px]">
        <div class={`mx-auto text-center ${isIndustry ? "border-t border-[#dddddd] pt-[72px]" : "max-w-[1280px]"}`}>
          <h2 class="text-[32px] font-extrabold leading-tight text-[#333333] md:text-[39px]">
            {title}
          </h2>
          {description && (
            <p class="mx-auto mt-4 max-w-[760px] text-[14px] leading-[1.8] text-[#666666] md:text-[16px]">
              {description}
            </p>
          )}
        </div>

        <div
          class={`grid gap-6 md:grid-cols-2 lg:grid-cols-3 ${isIndustry ? "mt-12" : "mt-10 md:mt-12"}`}
          data-pagination-grid
        >
          {
            articles.map((article, index) => {
              const page = Math.floor(index / pageSize) + 1;

              return (
                <div
                  data-pagination-item
                  data-page={page}
                  class={page === 1 ? "" : "hidden"}
                >
                  <BlogCard article={article} variant={variant} />
                </div>
              );
            })
          }
        </div>

        {
          totalPages > 1 && (
            <div
              class={`mt-10 flex px-4 sm:px-0 ${paginationAlign === "center" ? "justify-center" : "justify-end"} ${isIndustry ? "md:mt-12" : "md:mt-10"}`}
            >
              <nav
                aria-label={paginationLabel}
                class="flex flex-wrap items-center gap-[10px] text-[14px] text-[#999999]"
                data-pagination-nav
              >
                <button
                  type="button"
                  class="inline-flex size-6 items-center justify-center leading-none text-[#333333] transition disabled:cursor-not-allowed disabled:opacity-35"
                  data-pagination-prev
                  aria-label="Previous page"
                >
                  <span class="inline-flex size-[18px] -translate-x-px items-center justify-center" aria-hidden="true">
                    <svg class="block" width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="m11 5-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </button>

                {
                  Array.from({ length: totalPages }, (_, index) => {
                    const page = index + 1;
                    const isFirstPage = page === 1;

                    return (
                      <button
                        type="button"
                        data-pagination-button
                        data-page-target={page}
                        aria-current={isFirstPage ? "page" : "false"}
                        class={`min-w-5 transition hover:text-[#333333] ${isFirstPage ? "font-semibold text-[#333333]" : ""}`}
                      >
                        {page}
                      </button>
                    );
                  })
                }

                <button
                  type="button"
                  class="inline-flex items-center gap-2 transition hover:text-[#333333] disabled:cursor-not-allowed disabled:opacity-35"
                  data-pagination-next
                >
                  <span>Next page</span>
                  <span class="inline-flex items-center justify-center text-[#333333]" aria-hidden="true">
                    <svg class="block" width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="m7 5 4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                </button>
              </nav>
            </div>
          )
        }
      </Container>
    </section>
  )
}

<script>
  const paginationRoots = Array.from(
    document.querySelectorAll("[data-blog-pagination-root]"),
  );

  const clampPage = (value, totalPages) => {
    if (!Number.isFinite(value)) return 1;
    return Math.min(Math.max(value, 1), totalPages);
  };

  const getPageFromUrl = (root) => {
    const param = root.getAttribute("data-pagination-param");
    const totalPages = Number.parseInt(
      root.getAttribute("data-pagination-total-pages") ?? "1",
      10,
    );

    if (!param || totalPages <= 1) return 1;

    const currentUrl = new URL(window.location.href);
    const rawPage = Number.parseInt(currentUrl.searchParams.get(param) ?? "1", 10);
    return clampPage(rawPage, totalPages);
  };

  const syncRoot = (root, nextPage, shouldUpdateUrl = false) => {
    const param = root.getAttribute("data-pagination-param");
    const totalPages = Number.parseInt(
      root.getAttribute("data-pagination-total-pages") ?? "1",
      10,
    );
    const anchor = root.getAttribute("data-pagination-anchor");
    const currentPage = clampPage(nextPage, totalPages);

    root.querySelectorAll("[data-pagination-item]").forEach((item) => {
      const itemPage = Number.parseInt(item.getAttribute("data-page") ?? "1", 10);
      item.classList.toggle("hidden", itemPage !== currentPage);
    });

    root.querySelectorAll("[data-pagination-button]").forEach((button) => {
      const buttonPage = Number.parseInt(
        button.getAttribute("data-page-target") ?? "1",
        10,
      );
      const isActive = buttonPage === currentPage;

      button.setAttribute("aria-current", isActive ? "page" : "false");
      button.classList.toggle("font-semibold", isActive);
      button.classList.toggle("text-[#333333]", isActive);
    });

    const previousButton = root.querySelector("[data-pagination-prev]");
    const nextButton = root.querySelector("[data-pagination-next]");

    if (previousButton instanceof HTMLButtonElement) {
      previousButton.disabled = currentPage <= 1;
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.disabled = currentPage >= totalPages;
    }

    if (!shouldUpdateUrl || !param) {
      return;
    }

    const currentUrl = new URL(window.location.href);

    if (currentPage <= 1) {
      currentUrl.searchParams.delete(param);
    } else {
      currentUrl.searchParams.set(param, String(currentPage));
    }

    if (anchor) {
      currentUrl.hash = anchor;
    }

    window.history.pushState({}, "", currentUrl);
  };

  if (paginationRoots.length) {
    paginationRoots.forEach((root) => {
      if (!(root instanceof HTMLElement) || root.dataset.paginationBound === "true") {
        return;
      }

      root.dataset.paginationBound = "true";
      syncRoot(root, getPageFromUrl(root));

      root.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const trigger = target.closest("[data-page-target], [data-pagination-prev], [data-pagination-next]");
        if (!(trigger instanceof HTMLButtonElement)) return;

        event.preventDefault();

        const totalPages = Number.parseInt(
          root.getAttribute("data-pagination-total-pages") ?? "1",
          10,
        );
        const currentPage = getPageFromUrl(root);

        let nextPage = currentPage;

        if (trigger.hasAttribute("data-pagination-prev")) {
          nextPage = currentPage - 1;
        } else if (trigger.hasAttribute("data-pagination-next")) {
          nextPage = currentPage + 1;
        } else {
          nextPage = Number.parseInt(
            trigger.getAttribute("data-page-target") ?? String(currentPage),
            10,
          );
        }

        nextPage = clampPage(nextPage, totalPages);

        if (nextPage === currentPage) {
          return;
        }

        syncRoot(root, nextPage, true);
        root.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });

    window.addEventListener("popstate", () => {
      paginationRoots.forEach((root) => {
        if (root instanceof HTMLElement) {
          syncRoot(root, getPageFromUrl(root));
        }
      });
    });
  }
</script>
