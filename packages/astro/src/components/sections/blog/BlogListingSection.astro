---
import type { BlogArticle } from "../../../lib/blog";
import Container from "../../ui/Container.astro";
import BlogCard from "../../ui/BlogCard.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  articles: BlogArticle[];
  variant?: "default" | "industry";
}

const { id, title, description, articles, variant = "default" } = Astro.props;
const isIndustry = variant === "industry";
---

<section id={id} class={isIndustry ? "pb-10 pt-14 md:pb-12 md:pt-20" : "pb-8 pt-10 md:pb-10 md:pt-14"}>
  <Container class="!max-w-[1200px]">
    <div class={`mx-auto text-center ${isIndustry ? "border-t border-[#dddddd] pt-[72px]" : "max-w-[1200px]"}`}>
      <h2 class="text-[32px] font-extrabold leading-tight text-[#333333] md:text-[39px]">
        {title}
      </h2>
      {description && (
        <p class="mx-auto mt-4 max-w-[760px] text-[14px] leading-[1.8] text-[#666666] md:text-[16px]">
          {description}
        </p>
      )}
    </div>

    <div class={`grid gap-6 md:grid-cols-2 lg:grid-cols-3 ${isIndustry ? "mt-12" : "mt-10 md:mt-12"}`}>
      {articles.map((article) => <BlogCard article={article} variant={variant} />)}
    </div>
  </Container>
</section>
