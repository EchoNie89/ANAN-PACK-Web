---
import Container from '../ui/Container.astro';
import LocalImage from '../ui/LocalImage.astro';
import SanityImage from '../ui/SanityImage.astro';
import AboutDropdown from './AboutDropdown.astro';
import ProductsMegaMenu from './ProductsMegaMenu.astro';
import ServicesDropdown from './ServicesDropdown.astro';
import SolutionsDropdown from './SolutionsDropdown.astro';
import {
  aboutMenuItems,
  navItems,
  serviceMenuItems,
  solutionMenuItems,
} from '../../data/home';
import { getProductMenuItems } from '../../lib/product-pages';
import { getLocalImage } from '../../lib/local-images';
import { getSiteName } from '../../lib/seo';

interface Props {
  activeNav?: string;
  openMenu?: 'products' | 'solutions' | 'services' | 'about';
}

const { activeNav = 'Home', openMenu } = Astro.props;
const siteName = getSiteName();
const headerLogoImage = getLocalImage('/images/home/anan-pack-logo.png');
const productMenuItems = await getProductMenuItems();

const normalizePath = (value: string) => {
  const [path = '/'] = value.split('#');
  return path === '/' ? '/' : path.replace(/\/+$/, '');
};

const currentPath = normalizePath(Astro.url.pathname);
const isCurrentPath = (href: string) => normalizePath(href) === currentPath;
---

<header
  class="sticky top-0 z-50 border-b border-border/60 bg-white/95 backdrop-blur"
>
  <Container
    class="flex h-16 items-center justify-between lg:h-[88px] lg:!max-w-[1280px]"
  >
    <a
      href="/"
      class="flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
      aria-label={`${siteName} home`}
    >
      <LocalImage
        src={headerLogoImage}
        alt={siteName}
        class="h-[33px] w-auto"
        loading="eager"
        sizes="167px"
        widths={[167, 334]}
        priority
      />
    </a>

    <nav
      class="hidden h-full items-center gap-5 text-base font-bold lg:flex"
      aria-label="Primary navigation"
      data-primary-nav
    >
      {
        navItems.map((item) =>
          item.label === 'Products' ? (
            <div
              class="group/nav relative flex h-full items-center"
              data-menu-root
            >
              <button
                type="button"
                data-menu-trigger="products"
                aria-controls="products-menu"
                aria-expanded={openMenu === 'products' ? 'true' : 'false'}
                class={`inline-flex items-center gap-1 leading-none transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === 'Products'
                    ? 'text-nav-highlight'
                    : 'text-ink hover:text-brand'
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                <span
                  class={`relative after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-nav-highlight after:content-[''] ${
                    activeNav === 'Products'
                      ? 'after:opacity-100'
                      : 'after:opacity-0'
                  }`}
                >
                  {item.label}
                </span>
                <svg
                  viewBox="0 0 20 20"
                  class="size-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <ProductsMegaMenu
                forceOpen={openMenu === 'products'}
                items={productMenuItems}
              />
            </div>
          ) : item.label === 'Solutions' ? (
            <div
              class="group/nav relative flex h-full items-center"
              data-menu-root
            >
              <button
                type="button"
                data-menu-trigger="solutions"
                aria-controls="solutions-menu"
                aria-expanded={openMenu === 'solutions' ? 'true' : 'false'}
                class={`inline-flex items-center gap-1 leading-none transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === 'Solutions'
                    ? 'text-nav-highlight'
                    : 'text-ink hover:text-brand'
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                <span
                  class={`relative after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-nav-highlight after:content-[''] ${
                    activeNav === 'Solutions'
                      ? 'after:opacity-100'
                      : 'after:opacity-0'
                  }`}
                >
                  {item.label}
                </span>
                <svg
                  viewBox="0 0 20 20"
                  class="size-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <SolutionsDropdown forceOpen={openMenu === 'solutions'} />
            </div>
          ) : item.label === 'Services' ? (
            <div
              class="group/nav relative flex h-full items-center"
              data-menu-root
            >
              <button
                type="button"
                data-menu-trigger="services"
                aria-controls="services-menu"
                aria-expanded={openMenu === 'services' ? 'true' : 'false'}
                class={`inline-flex items-center gap-1 leading-none transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === 'Services'
                    ? 'text-nav-highlight'
                    : 'text-ink hover:text-brand'
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                <span
                  class={`relative after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-nav-highlight after:content-[''] ${
                    activeNav === 'Services'
                      ? 'after:opacity-100'
                      : 'after:opacity-0'
                  }`}
                >
                  {item.label}
                </span>
                <svg
                  viewBox="0 0 20 20"
                  class="size-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <ServicesDropdown forceOpen={openMenu === 'services'} />
            </div>
          ) : item.label === 'About Us' ? (
            <div
              class="group/nav relative flex h-full items-center gap-1"
              data-menu-root
            >
              <a
                href={item.href}
                class={`relative inline-flex items-center leading-none transition after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-nav-highlight after:content-[''] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === 'About Us'
                    ? 'text-nav-highlight after:opacity-100'
                    : 'text-ink after:opacity-0 hover:text-brand'
                }`}
              >
                {item.label}
              </a>
              <button
                type="button"
                data-menu-trigger="about"
                aria-controls="about-menu"
                aria-expanded={openMenu === 'about' ? 'true' : 'false'}
                class={`inline-flex items-center leading-none transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === 'About Us'
                    ? 'text-nav-highlight'
                    : 'text-ink hover:text-brand'
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                <span class="sr-only">Open About Us menu</span>
                <svg
                  viewBox="0 0 20 20"
                  class="size-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <AboutDropdown forceOpen={openMenu === 'about'} />
            </div>
          ) : (
            <a
              href={item.href}
              class={`relative inline-flex items-center leading-none transition after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-full after:bg-nav-highlight after:content-[''] hover:text-brand focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                activeNav === item.label
                  ? 'text-nav-highlight after:opacity-100'
                  : 'text-ink after:opacity-0 hover:text-brand'
              }`}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <div class="relative lg:hidden" data-mobile-nav data-open="false">
      <button
        type="button"
        class="relative z-[60] flex cursor-pointer items-center rounded-button border border-border px-4 py-2 text-xs font-bold uppercase text-ink"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-navigation"
        data-mobile-nav-trigger
      >
        Menu
      </button>
      <button
        type="button"
        class="fixed inset-x-0 bottom-0 top-16 z-40 bg-black/18 backdrop-blur-[1px]"
        aria-label="Close navigation menu"
        data-mobile-nav-backdrop
        hidden></button>
      <nav
        id="mobile-navigation"
        class="fixed inset-x-4 top-[72px] z-50 grid max-h-[calc(100dvh-96px)] gap-2 overflow-y-auto overscroll-contain rounded-panel border border-border bg-white p-4 text-sm font-semibold shadow-soft sm:left-auto sm:w-72"
        aria-label="Mobile navigation"
        data-mobile-nav-panel
        tabindex="-1"
        hidden
      >
        {
          navItems.map((item) =>
            item.label === 'Products' ? (
              <details class="rounded px-2 py-2 hover:bg-surface-muted">
                <summary
                  class={`flex cursor-pointer list-none items-center justify-between ${
                    activeNav === 'Products' ? 'text-brand-dark' : 'text-ink'
                  }`}
                >
                  Products
                  <svg
                    viewBox="0 0 16 16"
                    class="size-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-2">
                  {productMenuItems.map((product) => (
                    <a
                      href={product.href}
                      class={`flex items-center gap-3 rounded p-2 ${
                        isCurrentPath(product.href)
                          ? 'bg-brand-soft/80 text-brand-dark'
                          : 'text-text-main hover:bg-surface-muted'
                      }`}
                    >
                      <SanityImage
                        image={product.image}
                        class="size-12 rounded object-cover"
                        loading="lazy"
                        sizes="48px"
                        widths={[48, 96]}
                      />
                      <span>{product.title}</span>
                    </a>
                  ))}
                </div>
              </details>
            ) : item.label === 'Solutions' ? (
              <details
                class="rounded px-2 py-2 hover:bg-surface-muted"
                open={openMenu === 'solutions'}
              >
                <summary
                  class={`flex cursor-pointer list-none items-center justify-between ${
                    activeNav === 'Solutions' ? 'text-brand-dark' : 'text-ink'
                  }`}
                >
                  Solutions
                  <svg
                    viewBox="0 0 16 16"
                    class="size-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-1">
                  {solutionMenuItems.map((solution) => (
                    <a
                      href={solution.href}
                      class={`rounded px-3 py-2 ${
                        isCurrentPath(solution.href)
                          ? 'bg-brand-soft/80 text-brand-dark'
                          : 'text-text-main hover:bg-surface-muted'
                      }`}
                    >
                      {solution.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : item.label === 'Services' ? (
              <details
                class="rounded px-2 py-2 hover:bg-surface-muted"
                open={activeNav === 'Services' || openMenu === 'services'}
              >
                <summary
                  class={`flex cursor-pointer list-none items-center justify-between ${
                    activeNav === 'Services' ? 'text-brand-dark' : 'text-ink'
                  }`}
                >
                  Services
                  <svg
                    viewBox="0 0 16 16"
                    class="size-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-1">
                  {serviceMenuItems.map((service) => (
                    <a
                      href={service.href}
                      class={`rounded px-3 py-2 ${
                        isCurrentPath(service.href)
                          ? 'bg-brand-soft/80 text-brand-dark'
                          : 'text-text-main hover:bg-surface-muted'
                      }`}
                    >
                      {service.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : item.label === 'About Us' ? (
              <details
                class="rounded px-2 py-2 hover:bg-surface-muted"
                open={activeNav === 'About Us' || openMenu === 'about'}
              >
                <summary
                  class={`flex cursor-pointer list-none items-center justify-between ${
                    activeNav === 'About Us' ? 'text-brand-dark' : 'text-ink'
                  }`}
                >
                  About Us
                  <svg
                    viewBox="0 0 16 16"
                    class="size-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-1">
                  {aboutMenuItems.map((aboutItem) => (
                    <a
                      href={aboutItem.href}
                      data-about-section-link
                      data-active={
                        activeNav === 'About Us' && aboutItem.href.endsWith('#our-story')
                          ? 'true'
                          : 'false'
                      }
                      class="rounded px-3 py-2 text-text-main hover:bg-surface-muted data-[active=true]:bg-brand-soft/80 data-[active=true]:text-brand-dark"
                    >
                      {aboutItem.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a
                class={`rounded px-2 py-2 ${
                  activeNav === item.label
                    ? 'bg-brand-soft/80 text-brand-dark'
                    : 'text-ink hover:bg-surface-muted'
                }`}
                href={item.href}
              >
                {item.label}
              </a>
            ),
          )
        }
      </nav>
    </div>
  </Container>
</header>

<script>
  const primaryNav = document.querySelector('[data-primary-nav]');

  if (primaryNav) {
    const triggers = Array.from(
      primaryNav.querySelectorAll('[data-menu-trigger]'),
    );
    const panels = Array.from(primaryNav.querySelectorAll('[data-menu-panel]'));
    const menuLinks = Array.from(
      document.querySelectorAll('[data-menu-link], [data-about-section-link]'),
    );
    const menuRoots = Array.from(
      primaryNav.querySelectorAll('[data-menu-root]'),
    );

    const normalizePath = (value) => {
      const [path = '/'] = String(value ?? '').split('#');
      if (path === '/') return '/';
      return path.replace(/\/+$/, '');
    };

    const syncActiveMenuLinks = () => {
      const currentPath = normalizePath(window.location.pathname);
      const currentHash = window.location.hash;

      menuLinks.forEach((link) => {
        const href = link.getAttribute('href') ?? '';
        const [pathPart, hashPart] = href.split('#');
        const isDefaultAboutSection =
          normalizePath(pathPart || '/') === '/about-us' &&
          currentPath === '/about-us' &&
          !currentHash &&
          hashPart === 'our-story';
        const isActive = hashPart
          ? normalizePath(pathPart || '/') === currentPath &&
            (`#${hashPart}` === currentHash || isDefaultAboutSection)
          : normalizePath(href) === currentPath;

        link.setAttribute('data-active', String(isActive));
      });
    };

    const setOpenMenu = (menuName) => {
      triggers.forEach((trigger) => {
        const isOpen = trigger.getAttribute('data-menu-trigger') === menuName;
        trigger.setAttribute('aria-expanded', String(isOpen));
      });

      panels.forEach((panel) => {
        const isOpen = panel.getAttribute('data-menu-panel') === menuName;
        panel.setAttribute('data-open', String(isOpen));
      });
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        const menuName = trigger.getAttribute('data-menu-trigger');
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        setOpenMenu(isOpen ? null : menuName);
      });
    });

    primaryNav.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('[data-menu-panel] a')) setOpenMenu(null);
    });

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest('[data-menu-root]')) setOpenMenu(null);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpenMenu(null);
    });

    menuRoots.forEach((menuRoot) => {
      menuRoot.addEventListener('pointerleave', () => {
        setOpenMenu(null);
      });
    });

    window.addEventListener('hashchange', syncActiveMenuLinks);
    syncActiveMenuLinks();
  }

  const mobileNav = document.querySelector('[data-mobile-nav]');

  if (mobileNav instanceof HTMLElement) {
    const mobileNavTrigger = mobileNav.querySelector(
      '[data-mobile-nav-trigger]',
    );
    const mobileNavPanel = mobileNav.querySelector('[data-mobile-nav-panel]');
    const mobileNavBackdrop = mobileNav.querySelector(
      '[data-mobile-nav-backdrop]',
    );
    const mobileNavLinks = Array.from(mobileNav.querySelectorAll('a'));
    const mobileHeader = mobileNav.closest('header');
    const inertTargets = Array.from(document.body.children).filter(
      (element) => element instanceof HTMLElement && element !== mobileHeader,
    );
    const focusableSelector =
      'a[href], button:not([disabled]), summary, [tabindex]:not([tabindex="-1"])';

    const getMobileNavFocusables = () => {
      if (!(mobileNavPanel instanceof HTMLElement)) return [];

      return Array.from(
        mobileNavPanel.querySelectorAll(focusableSelector),
      ).filter(
        (element) =>
          element instanceof HTMLElement &&
          !element.hasAttribute('hidden') &&
          element.getAttribute('aria-hidden') !== 'true',
      );
    };

    const setInertSiblings = (isInert) => {
      inertTargets.forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        element.inert = isInert;
      });
    };

    const setMobileNavOpen = (isOpen, { restoreFocus = true } = {}) => {
      mobileNav.dataset.open = String(isOpen);

      if (mobileNavTrigger instanceof HTMLButtonElement) {
        mobileNavTrigger.setAttribute('aria-expanded', String(isOpen));
        mobileNavTrigger.setAttribute(
          'aria-label',
          isOpen ? 'Close navigation menu' : 'Open navigation menu',
        );
      }

      if (mobileNavBackdrop instanceof HTMLButtonElement) {
        mobileNavBackdrop.hidden = !isOpen;
      }

      if (mobileNavPanel instanceof HTMLElement) {
        mobileNavPanel.hidden = !isOpen;
      }

      setInertSiblings(isOpen);

      if (isOpen) {
        window.requestAnimationFrame(() => {
          const [firstFocusable] = getMobileNavFocusables();
          firstFocusable?.focus();
        });
      } else if (
        restoreFocus &&
        mobileNavTrigger instanceof HTMLButtonElement
      ) {
        mobileNavTrigger.focus();
      }
    };

    const closeMobileNav = (options) => {
      if (mobileNav.dataset.open !== 'true') return;
      setMobileNavOpen(false, options);
    };

    if (mobileNavTrigger instanceof HTMLButtonElement) {
      mobileNavTrigger.addEventListener('click', () => {
        setMobileNavOpen(mobileNav.dataset.open !== 'true', {
          restoreFocus: false,
        });
      });
    }

    if (mobileNavBackdrop instanceof HTMLButtonElement) {
      mobileNavBackdrop.addEventListener('click', closeMobileNav);
    }

    mobileNavLinks.forEach((link) => {
      link.addEventListener('click', closeMobileNav);
    });

    document.addEventListener('pointerdown', (event) => {
      if (mobileNav.dataset.open !== 'true') return;

      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('[data-mobile-nav-panel]')) return;
      if (target.closest('[data-mobile-nav-trigger]')) return;

      closeMobileNav();
    });

    document.addEventListener('keydown', (event) => {
      if (mobileNav.dataset.open !== 'true') return;

      if (event.key === 'Escape') {
        closeMobileNav();
        return;
      }

      if (event.key !== 'Tab') return;

      const focusables = getMobileNavFocusables();
      if (focusables.length === 0) {
        event.preventDefault();
        mobileNavPanel?.focus();
        return;
      }

      const firstFocusable = focusables[0];
      const lastFocusable = focusables[focusables.length - 1];
      const activeElement = document.activeElement;

      if (
        !(activeElement instanceof HTMLElement) ||
        !mobileNavPanel?.contains(activeElement)
      ) {
        event.preventDefault();
        firstFocusable.focus();
        return;
      }

      if (event.shiftKey && activeElement === firstFocusable) {
        event.preventDefault();
        lastFocusable.focus();
        return;
      }

      if (!event.shiftKey && activeElement === lastFocusable) {
        event.preventDefault();
        firstFocusable.focus();
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024) closeMobileNav({ restoreFocus: false });
    });

    setMobileNavOpen(false);
  }
</script>
