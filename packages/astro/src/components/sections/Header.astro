---
import Container from "../ui/Container.astro";
import LocalImage from "../ui/LocalImage.astro";
import ProductsMegaMenu from "./ProductsMegaMenu.astro";
import ServicesDropdown from "./ServicesDropdown.astro";
import SolutionsDropdown from "./SolutionsDropdown.astro";
import { navItems, productMenuItems, serviceMenuItems, solutionMenuItems } from "../../data/home";

interface Props {
  activeNav?: string;
  openMenu?: "products" | "solutions" | "services";
}

const { activeNav = "Home", openMenu } = Astro.props;

const normalizePath = (value: string) => {
  const [path = "/"] = value.split("#");
  return path === "/" ? "/" : path.replace(/\/+$/, "");
};

const currentPath = normalizePath(Astro.url.pathname);
const isCurrentPath = (href: string) => normalizePath(href) === currentPath;
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-white/95 backdrop-blur">
  <Container class="flex h-16 items-center justify-between lg:h-[88px] lg:!max-w-[1200px]">
    <a
      href="/home"
      class="flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2"
      aria-label="Tagora home"
    >
      <img
        src="/images/home/logoipsum-header.svg"
        alt="Logoipsum"
        class="h-10 w-auto md:h-[60px]"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav
      class="hidden h-full items-center gap-5 text-base font-bold lg:flex"
      aria-label="Primary navigation"
      data-primary-nav
    >
      {
        navItems.map((item) =>
          item.label === "Products" ? (
            <div class="group/nav relative flex h-full items-center" data-menu-root>
              <button
                type="button"
                data-menu-trigger="products"
                aria-controls="products-menu"
                aria-expanded={openMenu === "products" ? "true" : "false"}
                class={`relative inline-flex items-center gap-1 leading-none transition after:absolute after:-bottom-2 after:left-0 after:h-0.5 after:w-full after:bg-nav-active after:content-[''] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === "Products" ? "text-nav-active after:opacity-100" : "text-ink after:opacity-0 hover:text-brand"
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                {item.label}
                <svg viewBox="0 0 20 20" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <ProductsMegaMenu forceOpen={openMenu === "products"} />
            </div>
          ) : item.label === "Solutions" ? (
            <div class="group/nav relative flex h-full items-center" data-menu-root>
              <button
                type="button"
                data-menu-trigger="solutions"
                aria-controls="solutions-menu"
                aria-expanded={openMenu === "solutions" ? "true" : "false"}
                class={`relative inline-flex items-center gap-1 leading-none transition after:absolute after:-bottom-2 after:left-0 after:h-0.5 after:w-full after:bg-nav-active after:content-[''] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === "Solutions" ? "text-nav-active after:opacity-100" : "text-ink after:opacity-0 hover:text-brand"
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                {item.label}
                <svg viewBox="0 0 20 20" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <SolutionsDropdown forceOpen={openMenu === "solutions"} />
            </div>
          ) : item.label === "Services" ? (
            <div class="group/nav relative flex h-full items-center" data-menu-root>
              <button
                type="button"
                data-menu-trigger="services"
                aria-controls="services-menu"
                aria-expanded={openMenu === "services" ? "true" : "false"}
                class={`relative inline-flex items-center gap-1 leading-none transition after:absolute after:-bottom-2 after:left-0 after:h-0.5 after:w-full after:bg-nav-active after:content-[''] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                  activeNav === "Services" ? "text-nav-active after:opacity-100" : "text-ink after:opacity-0 hover:text-brand"
                } cursor-pointer border-0 bg-transparent p-0 text-base font-bold`}
                aria-haspopup="true"
              >
                {item.label}
                <svg viewBox="0 0 20 20" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path d="m5 8 5 5 5-5" />
                </svg>
              </button>
              <ServicesDropdown forceOpen={openMenu === "services"} />
            </div>
          ) : (
            <a
              href={item.href}
              class={`inline-flex items-center leading-none transition hover:text-brand focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${
                activeNav === item.label ? "text-nav-active" : "text-ink"
              }`}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <details class="relative lg:hidden">
      <summary class="flex cursor-pointer list-none items-center rounded-button border border-border px-4 py-2 text-xs font-bold uppercase text-ink">
        Menu
      </summary>
      <nav
        class="absolute right-0 top-12 grid max-h-[75vh] w-72 gap-2 overflow-y-auto rounded-panel border border-border bg-white p-4 text-sm font-semibold shadow-soft"
        aria-label="Mobile navigation"
      >
        {
          navItems.map((item) =>
            item.label === "Products" ? (
              <details class="rounded px-2 py-2 hover:bg-surface-muted">
                <summary class="flex cursor-pointer list-none items-center justify-between text-brand">
                  Products
                  <svg viewBox="0 0 16 16" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-2">
                  {productMenuItems.map((product) => (
                    <a
                      href={product.href}
                      class={`flex items-center gap-3 rounded p-2 ${
                        isCurrentPath(product.href) ? "bg-brand-soft/60 text-brand" : "text-text-main"
                      }`}
                    >
                      <LocalImage
                        src={product.image}
                        alt=""
                        class="size-12 rounded object-cover"
                        loading="lazy"
                        sizes="48px"
                        widths={[48, 96]}
                      />
                      <span>{product.title}</span>
                    </a>
                  ))}
                </div>
              </details>
            ) : item.label === "Solutions" ? (
              <details class="rounded px-2 py-2 hover:bg-surface-muted" open={openMenu === "solutions"}>
                <summary class="flex cursor-pointer list-none items-center justify-between text-brand">
                  Solutions
                  <svg viewBox="0 0 16 16" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-1">
                  {solutionMenuItems.map((solution) => (
                    <a
                      href={solution.href}
                      class={`rounded px-3 py-2 ${
                        solution.tone === "tan"
                          ? "bg-[#d4aa77] text-white"
                          : solution.tone === "highlight"
                            ? "bg-[#ffc76e] text-black"
                            : "text-text-main"
                      }`}
                    >
                      {solution.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : item.label === "Services" ? (
              <details class="rounded px-2 py-2 hover:bg-surface-muted" open={activeNav === "Services" || openMenu === "services"}>
                <summary class="flex cursor-pointer list-none items-center justify-between text-brand">
                  Services
                  <svg viewBox="0 0 16 16" class="size-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="m4 6 4 4 4-4" />
                  </svg>
                </summary>
                <div class="mt-3 grid gap-1">
                  {serviceMenuItems.map((service) => (
                    <a
                      href={service.href}
                      class={`rounded px-3 py-2 ${
                        service.tone === "tan" ? "bg-[#d4aa77] text-white" : "bg-[#fffffa] text-text-main"
                      }`}
                    >
                      {service.title}
                    </a>
                  ))}
                </div>
              </details>
            ) : (
              <a class="rounded px-2 py-2 hover:bg-surface-muted" href={item.href}>{item.label}</a>
            )
          )
        }
      </nav>
    </details>
  </Container>
</header>

<script>
  const primaryNav = document.querySelector("[data-primary-nav]");

  if (primaryNav) {
    const triggers = Array.from(primaryNav.querySelectorAll("[data-menu-trigger]"));
    const panels = Array.from(primaryNav.querySelectorAll("[data-menu-panel]"));
    const menuLinks = Array.from(primaryNav.querySelectorAll("[data-menu-link]"));
    const menuRoots = Array.from(primaryNav.querySelectorAll("[data-menu-root]"));

    const normalizePath = (value) => {
      const [path = "/"] = String(value ?? "").split("#");
      if (path === "/") return "/";
      return path.replace(/\/+$/, "");
    };

    const syncActiveMenuLinks = () => {
      const currentPath = normalizePath(window.location.pathname);
      const currentHash = window.location.hash;

      menuLinks.forEach((link) => {
        const href = link.getAttribute("href") ?? "";
        const [pathPart, hashPart] = href.split("#");
        const isActive = hashPart
          ? normalizePath(pathPart || "/") === currentPath && `#${hashPart}` === currentHash
          : normalizePath(href) === currentPath;

        link.setAttribute("data-active", String(isActive));
      });
    };

    const setOpenMenu = (menuName) => {
      triggers.forEach((trigger) => {
        const isOpen = trigger.getAttribute("data-menu-trigger") === menuName;
        trigger.setAttribute("aria-expanded", String(isOpen));
      });

      panels.forEach((panel) => {
        const isOpen = panel.getAttribute("data-menu-panel") === menuName;
        panel.setAttribute("data-open", String(isOpen));
      });
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        const menuName = trigger.getAttribute("data-menu-trigger");
        const isOpen = trigger.getAttribute("aria-expanded") === "true";
        setOpenMenu(isOpen ? null : menuName);
      });
    });

    primaryNav.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest("[data-menu-panel] a")) setOpenMenu(null);
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (!target.closest("[data-menu-root]")) setOpenMenu(null);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setOpenMenu(null);
    });

    menuRoots.forEach((menuRoot) => {
      menuRoot.addEventListener("pointerleave", () => {
        setOpenMenu(null);
      });
    });

    window.addEventListener("hashchange", syncActiveMenuLinks);
    syncActiveMenuLinks();
  }
</script>
