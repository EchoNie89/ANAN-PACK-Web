---
import Container from "../ui/Container.astro";
import ImageCard from "../ui/ImageCard.astro";
import SectionTitle from "../ui/SectionTitle.astro";
import { industries } from "../../data/home";
---

<section id="solutions" class="bg-surface-muted py-16 md:py-20">
  <Container>
    <SectionTitle eyebrow="Tailored Solutions" title="Solutions Designed For Your Industry" />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {industries.map((industry) => <ImageCard {...industry} action="Go" />)}
    </div>
  </Container>
</section>
