---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { getLocalImage } from "../../../lib/local-images";

const storyFlatlayImage = getLocalImage("/images/about/about-story-flatlay.png");
const storyPackingImage = getLocalImage("/images/about/about-story-packing.png");
---

<section id="our-story" class="bg-white py-16 md:py-24">
  <Container class="!max-w-[1280px]">
    <div class="space-y-14 md:space-y-20 lg:space-y-[120px]">
      <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-start lg:gap-[52px]">
        <div class="overflow-hidden rounded-[4px] shadow-card" data-reveal>
          <LocalImage
            src={storyFlatlayImage}
            alt="Custom hang tags, labels, and trim materials laid out on a work surface"
            class="aspect-[591/380] size-full object-cover"
            loading="lazy"
            sizes="(min-width: 1024px) 46vw, 100vw"
            widths={[480, 640, 800, 960, 1200]}
          />
        </div>

        <div class="space-y-5 lg:pl-1" data-reveal style="--reveal-delay: 100ms;">
          <p class="text-base font-extrabold uppercase tracking-[0.03em] text-brand">WHO WE ARE</p>
          <h2 class="max-w-[591px] text-[22px] font-extrabold leading-[1.3] tracking-[0.02em] text-text-main md:text-[24px]">
            ANAN PACK Is A Packaging And Trim Supply Chain Partner For Apparel, Home Textile, Lifestyle, And E-Commerce Brands.
          </h2>
          <div class="max-w-[591px] space-y-3 text-[15px] leading-[26px] text-text-main md:space-y-4">
            <p>
              We are not a single factory. Instead, we integrate a network of audited manufacturing partners and manage multi-category packaging projects through one coordinated process.
            </p>
            <p>
              From labels, hang tags, stickers, paper bags, poly bags, boxes, and other packaging materials, we help brands simplify sourcing, reduce supplier fragmentation, and improve project visibility.
            </p>
          </div>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-[0.98fr_1.02fr] lg:items-start lg:gap-[52px]">
        <div class="space-y-5 lg:pr-1" data-reveal>
          <p class="text-base font-extrabold tracking-[0.03em] text-brand">Why We Started ANAN PACK</p>
          <h2 class="max-w-[591px] text-[22px] font-extrabold leading-[1.3] tracking-[0.02em] text-text-main md:text-[24px]">
            We Were Created To Solve The Real Challenges Of Sourcing In China
          </h2>
          <div class="max-w-[591px] space-y-3 text-[15px] leading-[26px] text-text-main md:space-y-4">
            <p>
              Many growing brands face the same challenge when sourcing packaging in China: different products require different suppliers, communication becomes fragmented, and quality standards are difficult to keep consistent.
            </p>
            <p>ANAN PACK was created to solve this problem.</p>
            <p>
              With experience in packaging sourcing, international trade, factory coordination, and quality follow-up, our team helps brands manage packaging projects with less risk, clearer communication, and more predictable delivery.
            </p>
          </div>
        </div>

        <div class="overflow-hidden rounded-[4px] shadow-card" data-reveal style="--reveal-delay: 100ms;">
          <LocalImage
            src={storyPackingImage}
            alt="A packaging shipment being checked and handed over"
            class="aspect-[591/380] size-full object-cover"
            loading="lazy"
            sizes="(min-width: 1024px) 46vw, 100vw"
            widths={[480, 640, 800, 960, 1200]}
          />
        </div>
      </div>
    </div>
  </Container>
</section>
