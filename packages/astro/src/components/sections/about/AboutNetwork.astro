---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { getLocalImage } from "../../../lib/local-images";

const networkImage = getLocalImage("/images/about/about-network-map-rectangle-75.png");
---

<section class="relative overflow-hidden bg-page-muted py-16 md:py-20 lg:h-[619px] lg:py-0">
  <LocalImage
    src={networkImage}
    alt="Map of China showing partner manufacturing regions connected to Guangzhou"
    class="absolute inset-0 size-full object-cover object-right"
    loading="lazy"
    sizes="100vw"
    widths={[640, 960, 1280, 1440]}
  />
  <div class="absolute inset-0 bg-white/22"></div>
  <Container class="relative !max-w-none lg:h-full lg:px-[140px]">
    <div class="lg:pt-[150px]">
      <p
        class="max-w-[620px] capitalize text-[20px] font-extrabold leading-[1.12] tracking-[0.03em] text-[#a67237] md:text-[24px]"
        data-reveal
      >
        Connected to China’s Packaging Manufacturing Network
      </p>
      <div
        class="mt-14 max-w-[900px] space-y-0 capitalize text-base font-normal leading-[1.28] text-[#333333] md:text-[20px] md:leading-[1.14]"
        data-reveal
        style="--reveal-delay: 80ms;"
      >
        <p>
          Based in China, ANAN PACK works closely with selected packaging and trim manufacturers across key production regions.
        </p>
        <p>
          This allows us to match the right factory resources based on your product category, quantity, quality requirements, and delivery schedule.
        </p>
      </div>
      <p
        class="mt-24 max-w-[1240px] capitalize text-[22px] font-bold leading-[1.22] text-[#333333] md:text-[28px]"
        data-reveal
        style="--reveal-delay: 160ms;"
      >
        Tell Us Your Product Category, Quantity, And Packaging Requirements — Our Team Will Help You Plan The Next Step.
      </p>
    </div>
  </Container>
</section>
