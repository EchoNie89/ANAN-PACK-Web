---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { getLocalImage } from "../../../lib/local-images";

const networkImage = getLocalImage("/images/about/about-network-map.png");
---

<section class="relative overflow-hidden bg-page-muted py-16 md:py-24">
  <LocalImage
    src={networkImage}
    alt="Map of China showing partner manufacturing regions connected to Guangzhou"
    class="absolute inset-0 size-full object-cover object-center opacity-90"
    loading="lazy"
    sizes="100vw"
    widths={[640, 960, 1280, 1600]}
  />
  <div class="absolute inset-0 bg-white/70"></div>
  <Container class="relative !max-w-[1280px]">
    <div class="max-w-[640px]">
      <p
        class="text-lg font-extrabold uppercase tracking-[0.03em] text-brand md:text-2xl"
        data-reveal
      >
        Connected to China’s Packaging Manufacturing Network
      </p>
      <div
        class="mt-10 space-y-6 text-base leading-8 text-text-main md:text-xl md:leading-9"
        data-reveal
        style="--reveal-delay: 80ms;"
      >
        <p>
          Based in China, ANAN PACK works closely with selected packaging and trim manufacturers across key production regions.
        </p>
        <p>
          This allows us to match the right factory resources based on your product category, quantity, quality requirements, and delivery schedule.
        </p>
      </div>
      <p
        class="mt-12 max-w-[960px] text-lg font-semibold leading-8 text-text-main md:text-xl"
        data-reveal
        style="--reveal-delay: 160ms;"
      >
        Tell us your product category, quantity, and packaging requirements. Our team will help you plan the next step.
      </p>
    </div>
  </Container>
</section>
