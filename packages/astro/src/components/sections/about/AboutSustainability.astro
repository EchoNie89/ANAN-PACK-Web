---
import Container from "../../ui/Container.astro";
import SectionTitle from "../../ui/SectionTitle.astro";
import { aboutSustainability } from "../../../data/company";
---

<section class="bg-page-muted py-16 md:py-24">
  <Container class="!max-w-[1200px]">
    <SectionTitle
      eyebrow="SUSTAINABLE & CERTIFIED MATERIAL OPTIONS"
      title="Supporting Your Brand’s Sustainability Goals."
      align="center"
    />
    <div class="mt-12 grid gap-8 md:grid-cols-3">
      {
        aboutSustainability.map((item) => (
          <article class="text-center">
            <div class="mx-auto flex h-32 items-center justify-center rounded-soft bg-white px-6 shadow-card">
              <img
                src={item.image}
                alt={item.alt}
                class="max-h-24 w-auto object-contain"
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3 class="mt-5 text-lg font-bold text-ink">{item.title}</h3>
            <p class="mt-3 text-sm leading-7 text-text-muted">{item.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
