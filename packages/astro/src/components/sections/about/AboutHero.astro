---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { getLocalImage } from "../../../lib/local-images";

const menuItems = [
  { label: "Our Story", href: "#our-story", active: true },
  { label: "Why Choose Us", href: "#why-choose-us" },
  { label: "Contact Us", href: "#about-contact-cta" },
] as const;

const heroImage = getLocalImage("/images/about/about-hero.png");
---

<section class="relative overflow-hidden bg-page-muted lg:h-[calc(100dvh-88px)]">
  <LocalImage
    src={heroImage}
    alt="Premium packaging collection arranged in a modern showroom"
    class="absolute inset-0 size-full object-cover object-center"
    loading="eager"
    sizes="100vw"
    widths={[640, 960, 1280, 1600, 1920]}
    priority
  />
  <div class="absolute inset-0 bg-white/5"></div>
  <Container class="!max-w-[1280px] px-4 py-20 sm:px-6 md:py-24 lg:h-full lg:min-h-0 lg:px-8 lg:py-24">
    <div>
      <div class="max-w-[530px] rounded-soft bg-white/54 p-6 backdrop-blur-[2px] lg:mt-12 lg:bg-transparent lg:p-0 lg:backdrop-blur-0">
        <h1
          class="motion-enter font-display text-4xl font-black leading-tight tracking-[-0.03em] text-[#111827] md:text-5xl"
          style="--motion-delay: 100ms;"
        >
          Your Packaging Supply Chain Partner In China
        </h1>
        <p
          class="motion-enter mt-5 max-w-[530px] text-base leading-8 text-[#4b5563]"
          style="--motion-delay: 200ms;"
        >
          We help apparel, home, and lifestyle brands manage packaging sourcing, production coordination, quality control, and delivery through one reliable system.
        </p>
      </div>

      <nav
        class="motion-enter mt-10 overflow-hidden rounded-none bg-surface-panel shadow-menu lg:absolute lg:left-[calc(50%+378px)] lg:top-0 lg:mt-0 lg:w-[226px] lg:-translate-x-1/2"
        aria-label="About page menu"
        data-about-menu
        style="--motion-delay: 280ms;"
      >
        {
          menuItems.map((item) => (
            <a
              href={item.href}
              data-about-menu-link
              data-active={item.active ? "true" : "false"}
              class="flex min-h-[51px] items-center justify-center bg-white px-4 text-center text-base font-bold text-black transition hover:brightness-95 data-[active=true]:bg-nav-dropdown-active data-[active=true]:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-inset"
            >
              {item.label}
            </a>
          ))
        }
      </nav>
    </div>
  </Container>
</section>

<script>
  const aboutMenu = document.querySelector('[data-about-menu]');

  if (aboutMenu instanceof HTMLElement) {
    const aboutMenuLinks = Array.from(
      aboutMenu.querySelectorAll('[data-about-menu-link]'),
    );

    const syncAboutMenuLinks = () => {
      const currentHash = window.location.hash || '#our-story';

      aboutMenuLinks.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        const href = link.getAttribute('href') ?? '';
        link.setAttribute('data-active', String(href === currentHash));
      });
    };

    window.addEventListener('hashchange', syncAboutMenuLinks);
    syncAboutMenuLinks();
  }
</script>
