---
import Container from "../../ui/Container.astro";
import SectionTitle from "../../ui/SectionTitle.astro";
import { aboutTeam } from "../../../data/company";
---

<section class="bg-white py-16 md:py-24">
  <Container class="!max-w-[1200px]">
    <SectionTitle
      eyebrow="THE TEAM BEHIND EVERY PROJECT"
      title="More Than a Supplier, We Are Your Supply Chain Partner."
      align="center"
    />
    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        aboutTeam.map((member) => (
          <article class="text-center">
            <div class="overflow-hidden rounded-soft bg-surface-muted shadow-card">
              <img
                src="/images/about/about-team-avatar.png"
                alt={member.name}
                class={`aspect-[1.38/1] size-full object-cover ${member.imageClass}`}
                loading="lazy"
                decoding="async"
              />
            </div>
            <h3 class="mt-6 text-xl font-semibold leading-8 text-text-main">{member.name}</h3>
            <p class="mt-3 text-sm leading-7 text-text-muted">{member.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
