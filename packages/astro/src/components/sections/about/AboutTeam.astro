---
import Container from "../../ui/Container.astro";
import SectionTitle from "../../ui/SectionTitle.astro";
import { getAboutTeamMembers } from "../../../lib/about-page";
import LocalImage from "../../ui/LocalImage.astro";
import SanityImage from "../../ui/SanityImage.astro";

const teamMembers = await getAboutTeamMembers();
---

<section class="bg-white py-16 md:py-24">
  <Container class="!max-w-[1200px]">
    <div data-reveal>
      <SectionTitle
        eyebrow="THE TEAM BEHIND EVERY PROJECT"
        title="More Than a Supplier, We Are Your Supply Chain Partner."
        align="center"
      />
    </div>
    <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {
        teamMembers.map((member, index) => (
          <article
            class="motion-hover-card text-center"
            data-reveal
            style={`--reveal-delay: ${index * 80}ms;`}
          >
            <div class="overflow-hidden rounded-soft bg-white shadow-card">
              {
                member.sanitySource ? (
                  <SanityImage
                    image={{
                      src: member.image,
                      alt: member.imageAlt,
                      sanityKey: member.sanityKey,
                      sanitySource: member.sanitySource,
                      width: member.width,
                      height: member.height,
                    }}
                    class={`aspect-[1.38/1] size-full object-cover ${member.imageClass ?? ""}`}
                    loading="lazy"
                    sizes="(min-width: 1280px) 18vw, (min-width: 768px) 42vw, 100vw"
                    widths={[320, 480, 640, 800]}
                  />
                ) : (
                  <LocalImage
                    src={member.image}
                    alt={member.imageAlt}
                    class={`aspect-[1.38/1] size-full object-cover ${member.imageClass ?? ""}`}
                    loading="lazy"
                    sizes="(min-width: 1280px) 18vw, (min-width: 768px) 42vw, 100vw"
                    widths={[320, 480, 640, 800]}
                  />
                )
              }
            </div>
            <h3 class="mt-6 text-xl font-semibold leading-8 text-text-main">{member.name}</h3>
            <p class="mt-3 text-sm leading-7 text-text-muted">{member.description}</p>
          </article>
        ))
      }
    </div>
  </Container>
</section>
