---
import Container from "../../ui/Container.astro";
import LocalImage from "../../ui/LocalImage.astro";
import { aboutReasons } from "../../../data/company";
---

<section id="why-choose-us" class="bg-[#f9f9f9] py-16 md:py-[78px]">
  <Container class="!max-w-[1280px]">
    <div class="mx-auto max-w-[720px] text-center" data-reveal>
      <p class="text-base font-extrabold tracking-[0.03em] text-[#a67237]">
        WHAT MAKES US DIFFERENT
      </p>
      <h2 class="mt-[23px] text-[22px] font-extrabold tracking-[0.03em] text-black md:text-[24px]">
        More Than A Supplier, We Are Your Supply Chain Partner.
      </h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2 md:mt-16 xl:grid-cols-4 xl:mt-[71px]">
      {
        aboutReasons.map((item, index) => (
          <div
            class="motion-hover-card flex min-h-[254px] flex-col items-center rounded-[10px] border border-black/10 bg-white px-5 pb-8 pt-10 text-center"
            data-reveal
            style={`--reveal-delay: ${index * 80}ms;`}
          >
            <LocalImage
              src={item.icon}
              alt={item.iconAlt}
              class="size-[60px] object-contain"
              loading="eager"
              sizes="60px"
              widths={[60, 120]}
              width={60}
              height={60}
            />
            <h3 class="mt-[29px] text-[16px] font-semibold leading-[normal] text-black">
              {item.title}
            </h3>
            <p class="mt-[18px] max-w-[250px] text-[14px] leading-[1.5] text-[#666666]">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
