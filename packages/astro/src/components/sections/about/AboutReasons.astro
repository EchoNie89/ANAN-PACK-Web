---
import Container from "../../ui/Container.astro";
import SectionTitle from "../../ui/SectionTitle.astro";
import IconFeature from "../../ui/IconFeature.astro";
import { aboutReasons } from "../../../data/company";
---

<section id="why-choose-us" class="bg-page-muted py-16 md:py-24">
  <Container class="!max-w-[1200px]">
    <SectionTitle
      eyebrow="WHAT MAKES US DIFFERENT"
      title="More Than A Supplier, We Are Your Supply Chain Partner."
      align="center"
    />
    <div class="mt-12 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
      {
        aboutReasons.map((item) => (
          <div class="rounded-soft border border-black/10 bg-white p-7 shadow-card">
            <IconFeature icon={item.icon} title={item.title} description={item.description} />
          </div>
        ))
      }
    </div>
  </Container>
</section>
