---
import type { SiteImageSource } from "../../lib/local-images";
import LocalImage from "./LocalImage.astro";

interface Props {
  image: SiteImageSource;
  title: string;
  alt: string;
  href?: string;
  action?: string;
  class?: string;
}

const {
  image,
  title,
  alt,
  href = "#",
  action = "Explore",
  class: className = "",
} = Astro.props;
---

<a
  href={href}
  class={`group block overflow-hidden rounded-panel border border-border bg-white shadow-card transition hover:-translate-y-1 hover:shadow-soft focus:outline-none focus-visible:ring-2 focus-visible:ring-brand focus-visible:ring-offset-2 ${className}`}
>
  <div class="aspect-[4/3] overflow-hidden bg-surface-muted">
    <LocalImage
      src={image}
      alt={alt}
      class="size-full object-cover transition duration-500 group-hover:scale-105"
      loading="lazy"
      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
      widths={[320, 480, 640, 720]}
      quality={60}
    />
  </div>
  <div class="flex items-center justify-between gap-4 px-5 py-4">
    <h3 class="text-sm font-bold text-ink">{title}</h3>
    <span class="inline-flex items-center gap-1.5 shrink-0 text-xs font-semibold text-brand-contrast transition group-hover:text-brand-dark">
      {action}
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14" />
        <path d="m13 5 7 7-7 7" />
      </svg>
    </span>
  </div>
</a>
