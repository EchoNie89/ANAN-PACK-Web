---
import { Image } from "astro:assets";
import type { SiteImageSource } from "../../lib/local-images";

interface Props {
  src: SiteImageSource;
  alt: string;
  "aria-hidden"?: "true" | "false";
  class?: string;
  loading?: "eager" | "lazy";
  sizes?: string;
  widths?: number[];
  width?: number;
  height?: number;
  quality?: number | "low" | "mid" | "high" | "max";
  priority?: boolean;
}

const {
  src,
  alt,
  ["aria-hidden"]: ariaHidden,
  class: className = "",
  loading = "lazy",
  sizes,
  widths,
  width,
  height,
  quality,
  priority = false,
} = Astro.props;
---

{
  typeof src === "string" ? (
    <img
      src={src}
      alt={alt}
      aria-hidden={ariaHidden}
      class={className}
      loading={loading}
      decoding="async"
      width={width}
      height={height}
      fetchpriority={priority ? "high" : undefined}
    />
  ) : (
    <Image
      src={src}
      alt={alt}
      aria-hidden={ariaHidden}
      class={className}
      loading={loading}
      widths={widths}
      sizes={sizes}
      width={width}
      height={height}
      quality={quality}
      priority={priority}
    />
  )
}
