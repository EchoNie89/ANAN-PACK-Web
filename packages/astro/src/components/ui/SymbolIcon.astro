---
interface Props {
  name:
    | "location"
    | "phone"
    | "mail"
    | "clock"
    | "upload"
    | "box"
    | "bolt"
    | "shield"
    | "globe"
    | "users"
    | "check";
  class?: string;
}

const { name, class: className = "size-5" } = Astro.props;
---

{
  name === "location" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 21s6-5.6 6-11a6 6 0 1 0-12 0c0 5.4 6 11 6 11Z" />
      <circle cx="12" cy="10" r="2.5" />
    </svg>
  )
}
{
  name === "phone" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M7.2 4.6c.3-.7 1-.9 1.7-.7l2.1.7c.7.2 1.1 1 1 1.7l-.4 2.2c-.1.4 0 .9.3 1.2l2.5 2.5c.3.3.8.4 1.2.3l2.2-.4c.7-.1 1.5.3 1.7 1l.7 2.1c.2.7 0 1.4-.7 1.7l-1 .5c-1.1.5-2.4.7-3.6.3-2.5-.8-4.7-2.2-6.6-4.1-1.9-1.9-3.3-4.1-4.1-6.6-.4-1.2-.2-2.5.3-3.6l.5-1Z" />
    </svg>
  )
}
{
  name === "mail" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2" />
      <path d="m4 7 8 6 8-6" />
    </svg>
  )
}
{
  name === "clock" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="M12 7v5l3 2" />
    </svg>
  )
}
{
  name === "upload" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 16V5m0 0-4 4m4-4 4 4" />
      <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
    </svg>
  )
}
{
  name === "box" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="m3 8.5 9-5 9 5-9 5-9-5Z" />
      <path d="M3 8.5V16l9 4.5 9-4.5V8.5M12 13.5V20" />
    </svg>
  )
}
{
  name === "bolt" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M13 2 5 13h5l-1 9 8-11h-5l1-9Z" />
    </svg>
  )
}
{
  name === "shield" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="m12 3 7 3v5c0 4.6-2.8 8.7-7 10-4.2-1.3-7-5.4-7-10V6l7-3Z" />
      <path d="m9 11.5 2 2 4-4" />
    </svg>
  )
}
{
  name === "globe" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" />
    </svg>
  )
}
{
  name === "users" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <circle cx="9" cy="8" r="3" />
      <circle cx="17" cy="9" r="2.5" />
      <path d="M4 19a5 5 0 0 1 10 0M15 18.5c.2-2 1.5-3.7 3.4-4.4" />
    </svg>
  )
}
{
  name === "check" && (
    <svg viewBox="0 0 24 24" class={className} fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <circle cx="12" cy="12" r="9" />
      <path d="m8.5 12 2.5 2.5 4.5-5" />
    </svg>
  )
}
