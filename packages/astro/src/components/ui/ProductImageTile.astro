---
import LocalImage from "./LocalImage.astro";
import type { SiteImageSource } from "../../lib/local-images";
import { resolveLocalImageSource } from "../../lib/local-images";

interface Props {
  image: SiteImageSource;
  alt: string;
  title: string;
  imageClass?: string;
}

const { image, alt, title, imageClass = "" } = Astro.props;
const resolvedImage = typeof image === "string" ? resolveLocalImageSource(image) : image;
---

<article class="group">
  <div class="aspect-[4/3] overflow-hidden border border-border bg-surface-muted">
    <LocalImage
      src={resolvedImage}
      alt={alt}
      class={`size-full object-cover transition duration-500 group-hover:scale-105 ${imageClass}`}
      loading="lazy"
      sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
      widths={[320, 480, 640, 800]}
    />
  </div>
  <h3 class="mt-3 text-center text-sm font-semibold leading-snug text-text-muted md:text-lg md:leading-tight">
    {title}
  </h3>
</article>
