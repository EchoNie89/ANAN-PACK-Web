---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "dark" | "soft";
  class?: string;
  target?: string;
  rel?: string;
}

const { href, variant = "primary", class: className = "", target, rel } = Astro.props;

const base =
  "inline-flex items-center justify-center rounded-button px-6 py-3 text-xs font-bold uppercase tracking-[0.02em] transition focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2";

const variants = {
  primary: "bg-brand text-white hover:bg-brand-dark",
  secondary:
    "border border-brand/40 bg-white/80 text-brand hover:border-brand hover:bg-white",
  dark: "bg-ink text-white hover:bg-text-main",
  soft: "bg-brand-soft text-text-main shadow-[0_8px_14px_rgba(0,0,0,0.18)] hover:bg-[#d9c7af]",
};

const classes = `${base} ${variants[variant]} ${className}`;
---

{
  href ? (
    <a href={href} class={classes} target={target} rel={rel}>
      <slot />
    </a>
  ) : (
    <button class={classes}>
      <slot />
    </button>
  )
}
