---
import type { SolutionIconName } from "../../data/solutions";

interface Props {
  icon: SolutionIconName;
  class?: string;
}

const { icon, class: className = "" } = Astro.props;
const figmaIconSrcByName = {
  stack: "/images/solutions/icons/challenge-stack.svg",
  sample: "/images/solutions/icons/challenge-sample.svg",
  refresh: "/images/solutions/icons/challenge-refresh.svg",
  chat: "/images/solutions/icons/challenge-chat.svg",
} satisfies Partial<Record<SolutionIconName, string>>;
const figmaIconSrc = figmaIconSrcByName[icon];
const imageClasses = `block size-9 ${className}`;
const svgClasses = `size-9 text-ink ${className}`;
---

{
  figmaIconSrc ? (
    <img src={figmaIconSrc} alt="" class={imageClasses} loading="eager" decoding="async" aria-hidden="true" />
  ) : (
    <svg viewBox="0 0 48 48" class={svgClasses} fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      {icon === "shield" && (
        <>
          <path d="M24 6 38 12v10c0 9-5.8 16.2-14 20-8.2-3.8-14-11-14-20V12z" />
          <path d="m17 24 5 5 10-12" />
        </>
      )}
      {icon === "spark" && (
        <>
          <path d="M24 6 28 20l14 4-14 4-4 14-4-14-14-4 14-4z" />
          <path d="M35 7v8" />
          <path d="M31 11h8" />
        </>
      )}
      {icon === "box" && (
        <>
          <path d="m8 16 16-8 16 8-16 8z" />
          <path d="M8 16v16l16 8 16-8V16" />
          <path d="M24 24v16" />
          <path d="m16 12 16 8" />
        </>
      )}
      {icon === "leaf" && (
        <>
          <path d="M39 9C22 9 11 17 11 31c0 5 4 8 9 8 12 0 19-13 19-30Z" />
          <path d="M14 35c6-9 14-15 25-19" />
        </>
      )}
    </svg>
  )
}
