---
import { Image } from "astro:assets";
import RatingStars from "./RatingStars.astro";
import type { ImageMetadata } from "astro";

interface Props {
  quote: string;
  name: string;
  date: string;
  usedFor: string;
  icon?: ImageMetadata;
}

const { quote, name, date, usedFor, icon } = Astro.props;
---

<article class="flex h-full flex-col rounded-card border border-border bg-surface-warm p-5 shadow-card">
  <p class="text-[64px] font-extrabold leading-[0.7] text-brand-soft md:text-[80px]">“</p>
  <blockquote class="-mt-3 min-h-[72px] text-[16px] font-semibold leading-[1.5] text-text-main">
    {quote}
  </blockquote>
  <div class="mt-5">
    <RatingStars />
  </div>
  <div class="mt-auto pt-5">
    <div class="min-h-[88px] border-t border-border pt-4">
      <div class="flex items-center gap-3">
        {icon && (
          <div class="flex size-[60px] shrink-0 items-center justify-center rounded-full border border-border bg-surface">
            <Image src={icon} alt="" class="size-auto max-h-[38px] max-w-[38px]" />
          </div>
        )}
        <div class="min-w-0">
          <p class="whitespace-pre-line text-[16px] font-bold leading-5 text-black capitalize">{name}</p>
          <p class="mt-1 text-[14px] font-medium leading-[1.5] text-text-muted">{date}</p>
        </div>
      </div>
    </div>
    <p
      class="mt-5 flex min-h-10 items-center justify-center rounded-[30px] bg-brand-soft/50 px-4 py-2.5 text-center text-[14px] leading-5 text-text-muted"
    >
      <span class="font-semibold">Used For:</span>&nbsp;<span class="font-normal">{usedFor}</span>
    </p>
  </div>
</article>
