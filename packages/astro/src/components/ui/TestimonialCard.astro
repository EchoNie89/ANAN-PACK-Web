---
import RatingStars from "./RatingStars.astro";

interface Props {
  quote: string;
  name: string;
  date: string;
  usedFor: string;
}

const { quote, name, date, usedFor } = Astro.props;
const initials = name
  .split(/[,\s]+/)
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0])
  .join("")
  .toUpperCase();
---

<article class="rounded-card border border-border bg-surface-warm p-6 shadow-card">
  <p class="text-6xl font-extrabold leading-none text-brand-soft">"</p>
  <blockquote class="-mt-3 min-h-24 text-sm font-semibold leading-6 text-text-main">
    {quote}
  </blockquote>
  <div class="mt-5">
    <RatingStars />
  </div>
  <div class="mt-5 border-t border-border pt-5">
    <div class="flex items-center gap-3">
      <div
        class="flex size-11 shrink-0 items-center justify-center rounded-full bg-surface-muted text-xs font-bold text-brand"
      >
        {initials}
      </div>
      <div>
        <p class="text-sm font-extrabold text-ink">{name}</p>
        <p class="mt-1 text-xs font-medium text-text-muted">{date}</p>
      </div>
    </div>
    <p
      class="mt-5 rounded-button bg-brand-soft/50 px-4 py-3 text-center text-xs font-semibold text-text-muted"
    >
      Used for: <span class="font-normal">{usedFor}</span>
    </p>
  </div>
</article>
