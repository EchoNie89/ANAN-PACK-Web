---
import Footer from '../../components/sections/Footer.astro';
import Header from '../../components/sections/Header.astro';
import PageCTA from '../../components/sections/PageCTA.astro';
import BlogCategoryHighlights from '../../components/sections/blog/BlogCategoryHighlights.astro';
import BlogListingSection from '../../components/sections/blog/BlogListingSection.astro';
import BlogPageHero from '../../components/sections/blog/BlogPageHero.astro';
import {
  blogCategories,
  getAllBlogArticles,
  getFeaturedBlogArticles,
  getIndustryInsightArticles,
} from '../../lib/blog';
import { getLocalImage } from '../../lib/local-images';
import Layout from '../../layouts/Layout.astro';

const blogIndexHeroImage = getLocalImage(
  '/images/blog/material-guide-hero.jpg',
);
const allBlogArticles = await getAllBlogArticles();
const featuredMaterialArticles = getFeaturedBlogArticles(allBlogArticles);
const industryInsightArticles = getIndustryInsightArticles(allBlogArticles);
---

<Layout
  title="Blog | Tagora Packaging & Trims"
  description="Expert guides on packaging materials, production decisions, and fashion industry insights."
>
  <Header activeNav="Blog" />
  <main>
    <BlogPageHero
      title="Blog"
      description="Expert Guides On Materials, Printing, And Production."
      backgroundImage={blogIndexHeroImage}
      variant="blog-index"
      breadcrumbsAlign="left"
      breadcrumbs={[{ label: 'Home', href: '/home' }, { label: 'Blog' }]}
    >
      <BlogCategoryHighlights slot="afterContent" categories={blogCategories} inHero />
    </BlogPageHero>
    <BlogListingSection
      id="material-guides"
      title="Master Your Materials"
      description="Learn how paper stocks, recyclable formats, and production details shape premium packaging results."
      articles={featuredMaterialArticles}
      pageSize={6}
      paginationParam="materialsPage"
      paginationAlign="center"
      paginationLabel="Featured blog pagination"
    />
    <BlogListingSection
      id="industry-insights"
      title="Industry Trends & Knowledge"
      articles={industryInsightArticles}
      variant="industry"
      pageSize={6}
      paginationParam="insightsPage"
      paginationAlign="end"
      paginationLabel="Blog pagination"
    />

    <PageCTA
      title="Need A Custom Template Or Dieline?"
      description="Stop searching for generic files. Send us your product size, and our engineers will help create a production-ready structure."
      href="/contact-us"
      buttonLabel="Contact Our Team"
      note="We'll reply within 6 hours."
      class="pt-2"
    />
  </main>
  <Footer />
</Layout>
