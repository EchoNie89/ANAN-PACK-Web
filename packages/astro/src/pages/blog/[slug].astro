---
import Footer from "../../components/sections/Footer.astro";
import Header from "../../components/sections/Header.astro";
import BlogPostPage from "../../components/sections/blog/BlogPostPage.astro";
import {
  getAllBlogArticles,
  getBlogArticleBySlug,
  getBlogCategory,
  type BlogArticle,
} from "../../lib/blog";
import Layout from "../../layouts/Layout.astro";
import {
  buildBlogPostingJsonLd,
  buildBreadcrumbJsonLd,
  resolveSeoImage,
  toAbsoluteUrl,
} from "../../lib/seo";

export async function getStaticPaths() {
  const articles = await getAllBlogArticles();

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article, articles },
  }));
}

interface Props {
  article?: BlogArticle;
  articles?: BlogArticle[];
}

const { article, articles = [] } = Astro.props as Props;
const allArticles = articles.length ? articles : await getAllBlogArticles();
const currentArticle = article ?? (await getBlogArticleBySlug(Astro.params.slug ?? ""));

const currentIndex = currentArticle
  ? allArticles.findIndex((entry) => entry.slug === currentArticle.slug)
  : -1;

const previousArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : undefined;
const nextArticle =
  currentIndex >= 0 && currentIndex < allArticles.length - 1
    ? allArticles[currentIndex + 1]
    : undefined;

const recentArticles = currentArticle
  ? allArticles.filter((entry) => entry.slug !== currentArticle.slug).slice(0, 5)
  : allArticles.slice(0, 5);
const categoryLabel = currentArticle
  ? getBlogCategory(currentArticle.category)?.label ?? currentArticle.category
  : undefined;
const blogHeroImageSrc = currentArticle
  ? resolveSeoImage(currentArticle.heroImage)?.src
  : undefined;
const seoJsonLd = currentArticle
  ? [
      buildBreadcrumbJsonLd([
        { label: "Home", href: "/" },
        { label: "Blog", href: "/blog" },
        { label: currentArticle.title },
      ]),
      buildBlogPostingJsonLd({
        title: currentArticle.title,
        description: currentArticle.metaDescription,
        url: toAbsoluteUrl(`/blog/${currentArticle.slug}`),
        image: blogHeroImageSrc ? toAbsoluteUrl(blogHeroImageSrc) : undefined,
        publishedTime: currentArticle.publishedAt,
        section: categoryLabel,
      }),
    ].filter(Boolean)
  : [];
---

{
  currentArticle && (
    <Layout
      title={`${currentArticle.title} | ANAN PACK Blog`}
      description={currentArticle.metaDescription}
      image={currentArticle.heroImage}
      openGraphType="article"
      schemaType="Article"
      jsonLd={seoJsonLd}
      articlePublishedTime={currentArticle.publishedAt}
      articleModifiedTime={currentArticle.publishedAt}
    >
      <Header activeNav="Blog" />
      <BlogPostPage
        article={currentArticle}
        previousArticle={previousArticle}
        nextArticle={nextArticle}
        recentArticles={recentArticles}
      />
      <Footer />
    </Layout>
  )
}
