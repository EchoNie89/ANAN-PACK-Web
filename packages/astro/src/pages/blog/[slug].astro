---
import Footer from "../../components/sections/Footer.astro";
import Header from "../../components/sections/Header.astro";
import BlogPostPage from "../../components/sections/blog/BlogPostPage.astro";
import {
  getAllBlogArticles,
  getBlogArticleBySlug,
  type BlogArticle,
} from "../../lib/blog";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const articles = await getAllBlogArticles();

  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article, articles },
  }));
}

interface Props {
  article?: BlogArticle;
  articles?: BlogArticle[];
}

const { article, articles = [] } = Astro.props as Props;
const allArticles = articles.length ? articles : await getAllBlogArticles();
const currentArticle = article ?? (await getBlogArticleBySlug(Astro.params.slug ?? ""));

const currentIndex = currentArticle
  ? allArticles.findIndex((entry) => entry.slug === currentArticle.slug)
  : -1;

const previousArticle = currentIndex > 0 ? allArticles[currentIndex - 1] : undefined;
const nextArticle =
  currentIndex >= 0 && currentIndex < allArticles.length - 1
    ? allArticles[currentIndex + 1]
    : undefined;

const recentArticles = currentArticle
  ? allArticles.filter((entry) => entry.slug !== currentArticle.slug).slice(0, 5)
  : allArticles.slice(0, 5);
---

{
  currentArticle && (
    <Layout title={`${currentArticle.title} | Tagora Blog`} description={currentArticle.metaDescription}>
      <Header activeNav="Blog" />
      <BlogPostPage
        article={currentArticle}
        previousArticle={previousArticle}
        nextArticle={nextArticle}
        recentArticles={recentArticles}
      />
      <Footer />
    </Layout>
  )
}
