---
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import SolutionPage from "../components/sections/solutions/SolutionPage.astro";
import { defaultSolution } from "../data/solutions";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title={`${defaultSolution.title} | ANAN PACK`}
  description={defaultSolution.metaDescription}
  canonicalPath={`/solutions/${defaultSolution.slug}`}
  image={defaultSolution.hero.image}
  noindex
>
  <Header activeNav="Solutions" />
  <SolutionPage page={defaultSolution} />
  <Footer />
</Layout>
