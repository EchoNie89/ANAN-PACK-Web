---
import AboutUs from "../components/sections/AboutUs.astro";
import CaseStudy from "../components/sections/CaseStudy.astro";
import Certifications from "../components/sections/Certifications.astro";
import CTA from "../components/sections/CTA.astro";
import Footer from "../components/sections/Footer.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import IndustrySolutions from "../components/sections/IndustrySolutions.astro";
import LogoCloud from "../components/sections/LogoCloud.astro";
import MetricsBar from "../components/sections/MetricsBar.astro";
import ProductRange from "../components/sections/ProductRange.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import TrustReasons from "../components/sections/TrustReasons.astro";
import ValueProps from "../components/sections/ValueProps.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Tagora Packaging & Trims for Fashion Brands"
  description="Factory-direct sourcing for custom hang tags, woven labels, packaging bags, patches, and trim solutions."
>
  <Header activeNav="Home" />
  <main>
    <Hero />
    <ValueProps />
    <IndustrySolutions />
    <ProductRange />
    <TrustReasons />
    <LogoCloud />
    <Certifications />
    <AboutUs />
    <CaseStudy />
    <Testimonials />
    <MetricsBar />
    <CTA />
  </main>
  <Footer />
</Layout>
