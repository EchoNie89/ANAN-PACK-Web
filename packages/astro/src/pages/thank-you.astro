---
import Footer from '../components/sections/Footer.astro';
import Header from '../components/sections/Header.astro';
import Container from '../components/ui/Container.astro';
import Layout from '../layouts/Layout.astro';
import { getSiteContactDetails } from '../lib/site-settings';

const contact = await getSiteContactDetails();
const whatsappHref = `https://wa.me/${contact.whatsapp.replace(/[^0-9]/g, '')}`;
const emailHref = `mailto:${contact.email}`;
---

<Layout
  title="Thank You | ANAN PACK"
  description="Your inquiry has been received. Our team will review your project details and get back to you within 24 hours."
  noindex
>
  <Header />
  <main id="main-content" tabindex="-1">
    <section class="bg-page-muted py-20 md:py-28">
      <Container class="!max-w-[720px]">
        <div class="rounded-soft bg-white p-8 shadow-card md:p-12 text-center">
          <div
            class="inline-flex w-fit mx-auto items-center rounded-full bg-brand-soft/55 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-brand"
          >
            Inquiry Received
          </div>
          <div
            class="mt-6 mx-auto flex size-[52px] items-center justify-center rounded-full bg-[#f1e9dd] text-[#ac7431]"
          >
            <svg
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 6 9 17l-5-5"></path>
            </svg>
          </div>
          <h1
            class="mt-6 text-3xl font-extrabold tracking-tight text-ink md:text-4xl"
          >
            Thank You For Your Inquiry
          </h1>
          <p class="mt-4 max-w-xl mx-auto text-sm leading-6 text-text-main">
            We've received your project details. Our team will review them and
            get back to you within 24 hours on business days.
          </p>
          <p class="mt-3 text-sm leading-6 text-text-muted">
            If your request is urgent, feel free to contact us via WhatsApp or
            email.
          </p>

          <div class="mt-8 grid gap-3 md:grid-cols-2 text-left">
            <div class="rounded-soft bg-surface-muted px-4 py-4">
              <p
                class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand"
              >
                Response Window
              </p>
              <p class="mt-2 text-sm leading-6 text-text-main">
                Expect a reply within 24 hours on business days.
              </p>
            </div>
            <div class="rounded-soft bg-surface-muted px-4 py-4">
              <p
                class="text-[11px] font-semibold uppercase tracking-[0.16em] text-brand"
              >
                Urgent Support
              </p>
              <p class="mt-2 text-sm leading-6 text-text-main">
                Contact us via <a
                  href={whatsappHref}
                  class="text-brand underline"
                  target="_blank"
                  rel="noopener noreferrer">WhatsApp</a
                > or <a href={emailHref} class="text-brand underline">email</a>.
              </p>
            </div>
          </div>

          <div class="mt-10">
            <a
              href="/"
              class="inline-flex items-center justify-center rounded-button bg-brand-dark px-6 py-3 text-xs font-bold uppercase tracking-[0.02em] text-white transition hover:bg-brand-deep focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2"
            >
              Back to Home
            </a>
          </div>
        </div>
      </Container>
    </section>
  </main>
  <Footer />
</Layout>
